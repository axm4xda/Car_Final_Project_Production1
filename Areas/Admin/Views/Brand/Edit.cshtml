@model Brand
@{
    ViewData["Title"] = "Marka Redaktə Et";
}
<div class="a-card">
    <div class="a-card-head">
        <div>Marka Redaktə Et – @Model.Name</div>
        <a asp-action="Index" class="btn-a ghost">← Geri</a>
    </div>
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div class="fg"><label>Ad</label><input asp-for="Name" class="fc" required></div>
        <div class="fg">
            <label>Logo (dəyişmək üçün seçin)</label>
            <input type="file" name="logoFile" class="fc" accept="image/*">
            @if (!string.IsNullOrEmpty(Model.LogoUrl)){<div style="margin-top:6px"><img src="@Model.LogoUrl" style="height:50px;border-radius:8px"></div>}
        </div>
        <button class="btn-a primary" type="submit">Yadda Saxla</button>
    </form>
</div>
