@model BlogCategory
@{
    ViewData["Title"] = "Kateqoriya Redaktə Et";
}
<div class="a-card">
    <div class="a-card-head">
        <div>Redaktə Et – @Model.Name</div>
        <a asp-action="Index" class="btn-a ghost">← Geri</a>
    </div>
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <div class="fg"><label>Ad</label><input asp-for="Name" class="fc" required></div>
        <div class="fg"><label>Slug (URL)</label><input asp-for="Slug" class="fc"></div>
        <button class="btn-a primary" type="submit">Yadda Saxla</button>
    </form>
</div>
