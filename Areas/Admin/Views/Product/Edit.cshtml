@model Product
@{
    ViewData["Title"] = "Məhsul Redaktə Et";
    var categories = ViewBag.Categories as SelectList;
}

<div class="a-card">
    <div class="a-card-head">
        <div>Məhsul Redaktə Et – @Model.Name</div>
        <a asp-action="Index" class="btn-a ghost">← Geri</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="a-alert green" style="margin-bottom:16px">✅ @TempData["Success"]</div>
    }

    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div class="f-row">
            <div class="fg">
                <label>Ad</label>
                <input asp-for="Name" class="fc" required>
            </div>
            <div class="fg">
                <label>Kateqoriya</label>
                <select asp-for="CategoryId" asp-items="@categories" class="fc">
                    <option value="">Seçin</option>
                </select>
            </div>
        </div>

        <div class="f-row">
            <div class="fg">
                <label>Qiymət ($)</label>
                <input asp-for="Price" class="fc" type="number" step="0.01" required>
            </div>
            <div class="fg">
                <label>Köhnə Qiymət ($)</label>
                <input asp-for="OldPrice" class="fc" type="number" step="0.01">
            </div>
        </div>

        <div class="f-row">
            <div class="fg">
                <label>Stok</label>
                <input asp-for="Stock" class="fc" type="number" required>
            </div>
            <div class="fg">
                <label>Slug (URL)</label>
                <input asp-for="Slug" class="fc" placeholder="otomatik-yaranir">
            </div>
        </div>

        <div class="f-row">
            <div class="fg">
                <label>Badge</label>
                <input asp-for="Badge" class="fc" placeholder="New, Sale, Hot">
            </div>
            <div class="fg">
                <label>Badge Rəngi</label>
                <input asp-for="BadgeColor" class="fc" placeholder="bg-primary-2">
            </div>
        </div>

        <div class="fg">
            <label>Təsvir</label>
            <textarea asp-for="Description" class="fc" rows="4"></textarea>
        </div>

        <div class="fg">
            <label>Thumbnail (dəyişmək üçün seçin)</label>
            <input type="file" name="thumbnailFile" class="fc" accept="image/*">
            @if (!string.IsNullOrEmpty(Model.ThumbnailUrl))
            {
                <div style="margin-top:8px">
                    <img src="@Model.ThumbnailUrl" style="height:70px;border-radius:8px;border:1px solid #e5e7eb;" alt="Thumbnail">
                </div>
            }
        </div>

        <div class="fg">
            <label>Əlavə Şəkillər</label>
            <input type="file" name="imageFiles" class="fc" accept="image/*" multiple>
        </div>

        <div style="display:flex;gap:20px;margin-bottom:18px">
            <label class="f-chk"><input asp-for="IsActive" type="checkbox"> Aktiv</label>
            <label class="f-chk"><input asp-for="IsFeatured" type="checkbox"> Seçilmiş</label>
        </div>

        <button class="btn-a primary" type="submit">Yadda Saxla</button>
    </form>
</div>

@if (Model.Images != null && Model.Images.Any())
{
    <div class="a-card" style="margin-top:24px">
        <div class="a-card-head">
            <div>Mövcud Şəkillər (@Model.Images.Count)</div>
        </div>
        <div style="display:flex;flex-wrap:wrap;gap:12px;padding:16px 0;">
            @foreach (var img in Model.Images.OrderBy(i => i.Order))
            {
                <div style="position:relative;display:inline-block;">
                    <img src="@img.ImageUrl"
                         style="width:110px;height:90px;object-fit:cover;border-radius:8px;border:1px solid #e5e7eb;">
                    @if (img.IsMain)
                    {
                        <span style="position:absolute;top:4px;left:4px;background:#16a34a;color:#fff;font-size:10px;padding:2px 6px;border-radius:4px;">Ana</span>
                    }
                    <form asp-action="DeleteImage" asp-route-id="@img.Id" method="post"
                          onsubmit="return confirm('Bu şəkli silmək istədiyinizdən əminsiniz?')"
                          style="position:absolute;top:4px;right:4px;">
                        @Html.AntiForgeryToken()
                        <button type="submit"
                                style="background:#ef4444;color:#fff;border:none;border-radius:4px;width:22px;height:22px;cursor:pointer;font-size:12px;line-height:1;">✕</button>
                    </form>
                </div>
            }
        </div>
    </div>
}
