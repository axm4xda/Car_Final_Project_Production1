@model IEnumerable<Review>
@{
    ViewData["Title"] = "Müştəri Rəyləri";
}
<div class="a-card">
    <div class="a-card-head">
        <div>Müştəri Rəyləri (@Model.Count())</div>
        <a asp-action="Create" class="btn-a primary">+ Yeni Rəy</a>
    </div>
    @if (Model.Any())
    {
        <div class="tbl-wrap">
            <table class="a-table">
                <thead><tr><th>Avatar</th><th>Müəllif</th><th>Rəy</th><th>Reytinq</th><th>Status</th><th>Tarix</th><th>Əməliyyat</th></tr></thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td>@if (!string.IsNullOrEmpty(r.AvatarUrl)){<img src="@r.AvatarUrl" class="thumb" alt="">}else{<span class="a-badge gray">Yoxdur</span>}</td>
                            <td>
                                <strong>@r.AuthorName</strong>
                                @if (!string.IsNullOrEmpty(r.AuthorTitle)){<br><small style="color:#6b7280">@r.AuthorTitle</small>}
                            </td>
                            <td style="max-width:300px">@(r.Content.Length > 80 ? r.Content[..80] + "..." : r.Content)</td>
                            <td>⭐ @r.Rating</td>
                            <td><span class="a-badge @(r.IsApproved ? "green" : "yellow")">@(r.IsApproved ? "Təsdiqlənmiş" : "Gözləyir")</span></td>
                            <td>@r.CreatedDate.ToString("dd.MM.yyyy")</td>
                            <td class="act-btns">
                                <form asp-action="ToggleApprove" asp-route-id="@r.Id" method="post" class="del-form">
                                    @Html.AntiForgeryToken()
                                    <button class="btn-a @(r.IsApproved ? "warning" : "success") btn-sm">@(r.IsApproved ? "❌" : "✅")</button>
                                </form>
                                <a asp-action="Edit" asp-route-id="@r.Id" class="btn-a info btn-sm">✏️</a>
                                <form asp-action="Delete" asp-route-id="@r.Id" method="post" class="del-form" onsubmit="return confirm('Silmək istəyirsiniz?')">
                                    @Html.AntiForgeryToken()
                                    <button class="btn-a danger btn-sm">🗑</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else{<div class="empty-st"><p>Hələ rəy yoxdur.</p></div>}
</div>
