@model Order
@{
    ViewData["Title"] = "Sifariş #" + Model.Id;
}
<div class="a-card">
    <div class="a-card-head">
        <div>Sifariş #@Model.Id</div>
        <a asp-action="Index" class="btn-a ghost">← Geri</a>
    </div>

    <div class="f-row" style="margin-bottom:24px">
        <div>
            <p style="font-size:13px;color:#6b7280;font-weight:600;margin-bottom:4px">Müştəri</p>
            <p><strong>@Model.FirstName @Model.LastName</strong></p>
            <p>@Model.Email</p>
            <p>@Model.Phone</p>
        </div>
        <div>
            <p style="font-size:13px;color:#6b7280;font-weight:600;margin-bottom:4px">Ünvan</p>
            <p>@Model.Street</p>
            <p>@Model.City, @Model.State @Model.PostalCode</p>
            <p>@Model.Country</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Note))
    {
        <div style="margin-bottom:24px;padding:12px 16px;background:#f9fafb;border-radius:8px">
            <p style="font-size:13px;color:#6b7280;font-weight:600;margin-bottom:4px">Qeyd</p>
            <p>@Model.Note</p>
        </div>
    }

    <div class="tbl-wrap" style="margin-bottom:24px">
        <table class="a-table">
            <thead><tr><th>Məhsul</th><th>Qiymət</th><th>Miqdar</th><th>Cəm</th></tr></thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Product?.Name</td>
                        <td>$@item.UnitPrice.ToString("N2")</td>
                        <td>@item.Quantity</td>
                        <td>$@item.TotalPrice.ToString("N2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div style="max-width:320px;margin-bottom:24px">
        <div style="display:flex;justify-content:space-between;padding:6px 0"><span>Alt Cəm:</span><span>$@Model.SubTotal.ToString("N2")</span></div>
        @if (Model.Discount > 0)
        {
            <div style="display:flex;justify-content:space-between;padding:6px 0;color:#059669"><span>Endirim:</span><span>-$@Model.Discount.ToString("N2")</span></div>
        }
        <div style="display:flex;justify-content:space-between;padding:6px 0"><span>Çatdırılma:</span><span>$@Model.ShippingCost.ToString("N2")</span></div>
        <div style="display:flex;justify-content:space-between;padding:8px 0;font-weight:700;font-size:16px;border-top:2px solid #e5e7eb"><span>Cəm:</span><span>$@Model.Total.ToString("N2")</span></div>
    </div>

    @if (Model.Payment != null)
    {
        <div style="margin-bottom:24px">
            <p style="font-size:13px;color:#6b7280;font-weight:600;margin-bottom:4px">Ödəniş</p>
            <p>Metod: <strong>@Model.Payment.Method</strong></p>
            <p>Status: <span class="a-badge @(Model.Payment.Status == PaymentStatus.Paid ? "green" : Model.Payment.Status == PaymentStatus.Failed ? "red" : "yellow")">@Model.Payment.Status</span></p>
            @if (!string.IsNullOrEmpty(Model.Payment.CardLastFour))
            {
                <p>Kart: **** @Model.Payment.CardLastFour</p>
            }
        </div>
    }

    <form asp-action="UpdateStatus" asp-route-id="@Model.Id" method="post" style="display:flex;align-items:flex-end;gap:12px">
        @Html.AntiForgeryToken()
        <div class="fg" style="margin-bottom:0">
            <label>Status Dəyiş</label>
            <select name="status" class="fc">
                @foreach (var s in Enum.GetValues<OrderStatus>())
                {
                    <option value="@s" selected="@(s == Model.Status)">@s</option>
                }
            </select>
        </div>
        <button class="btn-a primary" type="submit">Yenilə</button>
    </form>
</div>
