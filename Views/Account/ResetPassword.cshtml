@{
    ViewData["Title"] = "Şifrə Sıfırlama";
    var email = (string?)ViewBag.Email ?? "";
    var token = (string?)ViewBag.Token ?? "";
}

<style>
    .rp-wrapper {
        max-width: 480px;
        margin: 60px auto;
        padding: 0 16px;
    }
    .rp-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 40px;
    }
    .rp-lock-icon {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: linear-gradient(135deg, #FF5722, #ff8a65);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
    }
    .rp-form-group {
        margin-bottom: 20px;
    }
    .rp-form-group label {
        display: block;
        font-size: 13px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
    }
    .rp-form-group input {
        width: 100%;
        padding: 12px 16px;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        font-size: 14px;
        transition: border-color 0.2s;
        outline: none;
        box-sizing: border-box;
    }
    .rp-form-group input:focus {
        border-color: #FF5722;
    }
    .rp-alert {
        padding: 14px 20px;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 500;
        margin-bottom: 20px;
    }
    .rp-alert--error {
        background: #fef2f2;
        color: #991b1b;
        border: 1px solid #fecaca;
    }
    .rp-alert--success {
        background: #ecfdf5;
        color: #065f46;
        border: 1px solid #a7f3d0;
    }
</style>

<!-- Breadcrumb -->
<section class="background-light">
    <div class="container">
        <ul class="breadcrumb">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li><img src="~/assets/icons/right.svg" alt="chevron-right"></li>
            <li><span>Şifrə Sıfırlama</span></li>
        </ul>
    </div>
</section>

<section class="pb-100">
    <div class="tf-spacing-style3"></div>
    <div class="rp-wrapper">
        <div class="rp-card">
            <div class="rp-lock-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                    <path d="M7 11V7C7 5.67 7.53 4.4 8.46 3.46C9.4 2.53 10.67 2 12 2C13.33 2 14.6 2.53 15.54 3.46C16.47 4.4 17 5.67 17 7V11"/>
                </svg>
            </div>
            <h2 style="text-align:center;margin-bottom:8px;">Yeni Şifrə Təyin Et</h2>
            <p style="text-align:center;color:#6b7280;font-size:14px;margin-bottom:32px;">
                <strong>@email</strong> üçün yeni şifrə daxil edin
            </p>

            @if (ViewBag.Error != null)
            {
                <div class="rp-alert rp-alert--error">
                    ⚠️ @ViewBag.Error
                </div>
            }

            <form method="post" asp-controller="Account" asp-action="ResetPassword">
                @Html.AntiForgeryToken()
                <input type="hidden" name="email" value="@email" />
                <input type="hidden" name="token" value="@token" />

                <div class="rp-form-group">
                    <label>Yeni Şifrə *</label>
                    <input type="password" name="password" placeholder="Yeni şifrə (min. 8 simvol)"
                           required minlength="8" autocomplete="new-password" />
                </div>

                <div class="rp-form-group">
                    <label>Yeni Şifrəni Təkrarla *</label>
                    <input type="password" name="confirmPassword" placeholder="Yeni şifrəni təkrarlayın"
                           required minlength="8" autocomplete="new-password" />
                </div>

                <div style="background:#f9fafb;border-radius:10px;padding:14px 16px;margin-bottom:24px;">
                    <p style="font-size:12px;color:#6b7280;margin:0;">
                        🔒 Şifrə tələbləri: Minimum 8 simvol, ən azı 1 böyük hərf və 1 rəqəm
                    </p>
                </div>

                <button type="submit" class="btn btn-primary btn-large font-weight-600" style="width:100%;">
                    Şifrəni Yenilə
                </button>
            </form>

            <p style="text-align:center;margin-top:20px;">
                <a asp-controller="Home" asp-action="Index" style="font-size:14px;color:#FF5722;font-weight:600;text-decoration:none;">
                    ← Ana Səhifəyə Qayıt
                </a>
            </p>
        </div>
    </div>
</section>
