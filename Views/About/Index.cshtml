										</a>
									</li>
								}
								@if (!string.IsNullOrEmpty(member.InstagramUrl))
								{
									<li>
										<a href="@member.InstagramUrl" target="_blank">
											<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><g clip-path="url(#clip0_13439_102351)"><path d="M10 13.125C11.7259 13.125 13.125 11.7259 13.125 10C13.125 8.27411 11.7259 6.875 10 6.875C8.27411 6.875 6.875 8.27411 6.875 10C6.875 11.7259 8.27411 13.125 10 13.125Z" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M13.75 2.5H6.25C4.17893 2.5 2.5 4.17893 2.5 6.25V13.75C2.5 15.8211 4.17893 17.5 6.25 17.5H13.75C15.8211 17.5 17.5 15.8211 17.5 13.75V6.25C17.5 4.17893 15.8211 2.5 13.75 2.5Z" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M14.0625 6.71875C14.494 6.71875 14.8438 6.36897 14.8438 5.9375C14.8438 5.50603 14.494 5.15625 14.0625 5.15625C13.631 5.15625 13.2812 5.50603 13.2812 5.9375C13.2812 6.36897 13.631 6.71875 14.0625 6.71875Z" fill="#fff"/></g></svg>
										</a>
									</li>
								}
								@if (!string.IsNullOrEmpty(member.SkypeUrl))
								{
									<li>
										<a href="@member.SkypeUrl" target="_blank">
											<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><g clip-path="url(#clip0_13439_102148)"><path d="M7.5 11.875C7.5 12.9102 8.61953 13.75 10 13.75C11.3805 13.75 12.5 12.9102 12.5 11.875C12.5 9.375 7.63906 10.3125 7.63906 8.125C7.63906 7.08984 8.61953 6.25 10 6.25C11.0352 6.25 11.8461 6.71875 12.1875 7.39531" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M16.7185 11.4599C17.2734 12.1817 17.5469 13.0806 17.4877 13.9891C17.4286 14.8976 17.0411 15.7536 16.3973 16.3973C15.7536 17.0411 14.8976 17.4286 13.9891 17.4877C13.0806 17.5469 12.1817 17.2734 11.4599 16.7185C10.3352 16.9617 9.16735 16.9188 8.06341 16.5939C6.95947 16.269 5.95465 15.6723 5.14094 14.8586C4.32722 14.0449 3.7306 13.0401 3.40567 11.9362C3.08074 10.8322 3.03789 9.66441 3.28103 8.53963C2.72612 7.81789 2.45272 6.91893 2.51182 6.01045C2.57093 5.10197 2.95851 4.24601 3.60226 3.60226C4.24601 2.95851 5.10197 2.57093 6.01045 2.51182C6.91893 2.39932 7.81789 2.94537 8.53963 3.28103C9.66441 3.03789 10.8322 3.08074 11.9362 3.40567C13.0401 3.7306 14.0449 4.32722 14.8586 5.14094C15.6723 5.95465 16.269 6.95947 16.5939 8.06341C16.9188 9.16735 16.9617 10.3352 16.7185 11.4599Z" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></g></svg>
										</a>
									</li>
								}
								@if (!string.IsNullOrEmpty(member.TelegramUrl))
								{
									<li>
										<a href="@member.TelegramUrl" target="_blank">
											<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><g clip-path="url(#clip0_13439_102153)"><path d="M6.24939 10.5366L13.301 16.7186C13.3822 16.7903 13.4806 16.8396 13.5867 16.8618C13.6927 16.8839 13.8027 16.8781 13.9058 16.845C14.0089 16.8118 14.1016 16.7524 14.1749 16.6726C14.2481 16.5928 14.2994 16.4953 14.3236 16.3897L17.4994 2.59521C17.5025 2.58138 17.5018 2.56696 17.4973 2.55351C17.4928 2.54006 17.4848 2.52807 17.474 2.51884C17.4633 2.50961 17.4502 2.50348 17.4362 2.5011C17.4223 2.49873 17.4079 2.5002 17.3947 2.50537L1.56189 8.70146C1.4636 8.73929 1.38023 8.80798 1.3243 8.89722C1.26837 8.98646 1.2429 9.09143 1.2517 9.19638C1.26051 9.30133 1.30312 9.4006 1.37313 9.47927C1.44315 9.55794 1.5368 9.61178 1.64001 9.63271L6.24939 10.5366Z" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M6.25 10.5375L17.4539 2.50781" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M9.71641 13.5789L7.325 16.0602C7.23859 16.1498 7.12737 16.2116 7.00561 16.2376C6.88384 16.2636 6.75708 16.2527 6.64157 16.2062C6.52607 16.1597 6.42709 16.0797 6.35732 15.9766C6.28755 15.8735 6.25018 15.7519 6.25 15.6273V10.5391" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></g></svg>
										</a>
									</li>
								}
							</ul>
						</div>

						<div class="card-bottom flex items-center justify-between gap-16">
							<div class="content">
								<a class="h5 font-weight-600 sale-agent-title"
								   asp-controller="SalesAgent" asp-action="Details" asp-route-id="@member.SalesAgentId">
									@member.Name
								</a>
								<p class="text-secondary text-sm">@member.Title</p>
							</div>
						</div>
					</div>
				}
			</div>
