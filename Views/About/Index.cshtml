@model Car_Project.ViewModels.About.AboutIndexViewModel
<!-- breadcrumb -->
<section class="background-light mb-32">
	<div class="container">
		<ul class="breadcrumb">
			<li>
				<a asp-controller="Home" asp-action="Index">Home</a>
			</li>
			<li>
				<img src="~/assets/icons/right.svg" alt="chevron-right">
			</li>
			<li>
				<span>About Us</span>
			</li>
		</ul>
	</div>
</section>
<!-- breadcrumb -->
<!-- About Us -->
<section class="pb-100">
	<div class="container">
		<h2>About Us</h2>
		<div class="tf-spacing-style3"></div>

		<div class="row">
			<div class="col-lg-6">
				<div class="about-box">
					<img class="main-img radius-16 wow fadeIn" data-wow-delay="0.1s" src="~/assets/images/pages/about-1.jpg" alt="">
					<div class="sub-img wow fadeInUp" data-wow-delay="0.2s">
						<img src="~/assets/images/pages/about-2.jpg" alt="">
					</div>
				</div>
			</div>
			<div class="col-lg-6">
				<div class="about-content">
					<h2 class="font-weight-600 mb-20">Driving Your Ultimate Automotive Dreams Forward</h2>

					<p class="text-secondary h7 line-height-28 mb-32">At Aurexo, we make car ownership simple and accessible with expert guidance, personalized solutions, and exceptional service. Our team is committed to helping you find the perfect vehicle while ensuring a hassle-free experience.</p>

					<ul class="flex flex-col gap-24 mb-32">
						<li class="flex gap-4">
							<img class="w-24 h-24" src="~/assets/icons/check.svg" alt="check">
							<p class="h5">Experienced Automotive Experts</p>
						</li>
						<li class="flex gap-4">
							<img class="w-24 h-24" src="~/assets/icons/check.svg" alt="check">
							<p class="h5">Transparent Pricing, No Hidden Fees</p>
						</li>
						<li class="flex gap-4">
							<img class="w-24 h-24" src="~/assets/icons/check.svg" alt="check">
							<p class="h5">Quick Process, Smooth Transactions</p>
						</li>
					</ul>

					<div class="flex gap-28 items-center">
						<a asp-controller="Contact" asp-action="Index" class="btn btn-primary btn-large font-weight-600">
							Contact Us
						</a>

						<a href="#" class="flex gap-16">
							<img src="~/assets/icons/PhoneCall-3.svg" alt="PhoneCall">
							<div class="mt2">
								<span class="text-sm text-secondary">Have any Question?</span>
								<p class="h4">1-555-678-8888</p>
							</div>
						</a>
					</div>
				</div>
			</div>
		</div>
	</div>

	<div class="tf-spacing-style5"></div>

	<!-- Client Reviews -->
	<section>
		<div class="container wow fadeIn" data-wow-delay="0.3s">
			<div class="title-section mb-40">
				<h2 class="">Clients Reviews</h2>
				<a asp-controller="Review" asp-action="Index" class="btn btn-line-style-2 effect-line-primary hover-fill-white btn-large">
					View All
					<svg width="17" height="17" viewBox="0 0 17 17" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M8.125 0C6.51803 0 4.94714 0.476523 3.611 1.36931C2.27485 2.2621 1.23344 3.53105 0.618482 5.0157C0.00352044 6.50035 -0.157382 8.13401 0.156123 9.71011C0.469628 11.2862 1.24346 12.7339 2.37976 13.8702C3.51606 15.0065 4.9638 15.7804 6.5399 16.0939C8.11599 16.4074 9.74966 16.2465 11.2343 15.6315C12.719 15.0166 13.9879 13.9752 14.8807 12.639C15.7735 11.3029 16.25 9.73197 16.25 8.125C16.2477 5.97081 15.391 3.90551 13.8677 2.38227C12.3445 0.85903 10.2792 0.00227486 8.125 0ZM11.6922 8.56719L9.19219 11.0672C9.07492 11.1845 8.91586 11.2503 8.75 11.2503C8.58415 11.2503 8.42509 11.1845 8.30782 11.0672C8.19054 10.9499 8.12466 10.7909 8.12466 10.625C8.12466 10.4591 8.19054 10.3001 8.30782 10.1828L9.74141 8.75H5C4.83424 8.75 4.67527 8.68415 4.55806 8.56694C4.44085 8.44973 4.375 8.29076 4.375 8.125C4.375 7.95924 4.44085 7.80027 4.55806 7.68306C4.67527 7.56585 4.83424 7.5 5 7.5H9.74141L8.30782 6.06719C8.19054 5.94991 8.12466 5.79085 8.12466 5.625C8.12466 5.45915 8.19054 5.30009 8.30782 5.18281C8.42509 5.06554 8.58415 4.99965 8.75 4.99965C8.91586 4.99965 9.07492 5.06554 9.19219 5.18281L11.6922 7.68281C11.7503 7.74086 11.7964 7.80979 11.8279 7.88566C11.8593 7.96154 11.8755 8.04287 11.8755 8.125C11.8755 8.20713 11.8593 8.28846 11.8279 8.36434C11.7964 8.44021 11.7503 8.50914 11.6922 8.56719Z" fill="#1C1C1C" />
					</svg>
				</a>
			</div>
			@if (Model.Reviews != null && Model.Reviews.Any())
			{
				<div class="swiper-container swiper-testimonior">
					<div class="swiper-wrapper">
						@foreach (var review in Model.Reviews)
						{
							<div class="swiper-slide">
								<div class="testimonior-box">
									<div class="flex items-center gap-4 mb-16">
										@for (int i = 1; i <= review.Rating; i++)
										{
											<img src="~/assets/icons/star-6.svg" alt="star">
										}
									</div>
									<p class="testimonior-box--desc mb-16">
										@review.Content
									</p>
									<div class="testimonior-box--user">
										@if (!string.IsNullOrEmpty(review.AvatarUrl))
										{
											<img class="testimonior--img" src="@review.AvatarUrl" alt="avatar">
										}
										else
										{
											<div class="testimonior--img" style="display:flex;align-items:center;justify-content:center;background:#e0e0e0;font-weight:600;font-size:1.1rem;">
												@(string.Concat(review.AuthorName.Split(' ').Take(2).Select(n => n[0].ToString().ToUpper())))
											</div>
										}
										<div class="testimonior-box--user-content">
											<p class="h5 title">@review.AuthorName</p>
											@if (!string.IsNullOrEmpty(review.AuthorTitle))
											{
												<p class="desc">@review.AuthorTitle</p>
											}
										</div>
									</div>
								</div>
							</div>
						}
					</div>
					<div class="swiper-pagination pagination-dark pagination-style pagination-swiper-testimonior mt-35"></div>
				</div>
			}
		</div>
	</section>
</section>
<!-- About Us -->

<!-- Why Choose Us -->
<section class="py-100 background-light">
	<div class="container">
		<div class="why-choose-us style2 style3">
			<div class="wow fadeIn" data-wow-delay="0.1s">
				<img class="move5" src="~/assets/images/card/why-choose-us.png" alt="why-choose-us">
			</div>

			<div class="wow fadeIn" data-wow-delay="0.2s">
				<h2 class="mb-12">Why Choose Us?</h2>
				<p class="text-muted mb-20">Explore our wide selection, competitive prices, and exceptional service for a hassle-free car-buying experience.</p>

				<ul class="list mb-32">
					<li class="flex items-center gap-12 mb-8 font-weight-500 h7 md-items-start">
						<img src="~/assets/icons/check.svg" alt="check">
						Wide Selection – A variety of cars to fit every need.
					</li>
					<li class="flex items-center gap-12 mb-8 font-weight-500 h7 md-items-start">
						<img src="~/assets/icons/check.svg" alt="check">
						Competitive Prices: Great deals and flexible financing.
					</li>
					<li class="flex items-center gap-12 mb-8 font-weight-500 h7 md-items-start">
						<img src="~/assets/icons/check.svg" alt="check">
						Trusted Service: Transparent, honest, and reliable.
					</li>
					<li class="flex items-center gap-12 mb-8 font-weight-500 h7 md-items-start">
						<img src="~/assets/icons/check.svg" alt="check">
						Excellent Support: Always here to assist you.
					</li>
				</ul>

				<a asp-controller="List" asp-action="Index" class="btn btn-primary btn-large font-weight-600 max-w-min">
					Find Your Car Now!
				</a>
			</div>
		</div>

		<!-- Stats Counters -->
		@if (Model.Stats != null && Model.Stats.Any())
		{
			<div class="grid grid-cols-4 gap-130 md-grid-cols-2 counter-spacing">
				@{ int delay = 1; }
				@foreach (var stat in Model.Stats)
				{
					bool isLast = stat == Model.Stats.Last();
					<div class="box-couter-item @(isLast ? "" : "outline-right") wow fadeInUp" data-wow-delay="0.@(delay)s">
						<div class="content">
							<div class="box-couter counter">
								<div class="number-content font-main-2">
									<span class="count-number font-main-2" data-to="@stat.Value" data-speed="1500" data-inviewport="yes">@stat.Value</span>@stat.Suffix
								</div>
							</div>
							<p class="font-weight-500 text-muted h7 text-center">@stat.Label</p>
						</div>
					</div>
					delay++;
				}
			</div>
		}
	</div>
</section>
<!-- Why Choose Us -->

<div class="tf-spacing"></div>

<!-- Executive Team -->
<section>
	<h2 class="mb-40 text-center">Executive Team</h2>
	<div class="container">
		@if (Model.TeamMembers != null && Model.TeamMembers.Any())
		{
			<div class="grid grid-cols-4 sm-grid-cols-1 lg-grid-cols-2 gap-30 xl-gap-16">
				@foreach (var member in Model.TeamMembers)
				{
					<div class="sale-agent-box">
						<div class="card-top mb-20">
							<a class="w-full flex"
							   asp-controller="SalesAgent" asp-action="Details" asp-route-id="@member.SalesAgentId">
								<img class="w-full"
								     src="@(member.ImageUrl ?? "~/assets/images/pages/sale-agent-1.jpg")"
