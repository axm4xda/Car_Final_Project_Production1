@{
    ViewData["Title"] = "Şifrə Dəyiş";
    var email = (string)ViewBag.Email;
}

<style>
    .dash-sidebar {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 24px 0;
        position: sticky;
        top: 100px;
    }
    .dash-sidebar .dash-nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 24px;
        font-size: 14px;
        font-weight: 500;
        color: #4b5563;
        text-decoration: none;
        transition: all 0.2s;
        border-left: 3px solid transparent;
    }
    .dash-sidebar .dash-nav-item:hover {
        background: #f9fafb;
        color: #1c1c1c;
    }
    .dash-sidebar .dash-nav-item.active {
        background: #fff5f2;
        color: #FF5722;
        border-left-color: #FF5722;
        font-weight: 600;
    }
    .dash-sidebar .dash-nav-item svg { flex-shrink: 0; }

    .cp-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 40px;
    }
    .cp-form-group {
        margin-bottom: 20px;
    }
    .cp-form-group label {
        display: block;
        font-size: 13px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
    }
    .cp-form-group input {
        width: 100%;
        padding: 12px 16px;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        font-size: 14px;
        transition: border-color 0.2s;
        outline: none;
    }
    .cp-form-group input:focus {
        border-color: #FF5722;
    }
    .cp-form-group input[disabled] {
        background: #f3f4f6;
        color: #9ca3af;
    }
    .cp-alert {
        padding: 14px 20px;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 500;
        margin-bottom: 20px;
    }
    .cp-alert--success {
        background: #ecfdf5;
        color: #065f46;
        border: 1px solid #a7f3d0;
    }
    .cp-alert--error {
        background: #fef2f2;
        color: #991b1b;
        border: 1px solid #fecaca;
    }
    .cp-lock-icon {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: linear-gradient(135deg, #FF5722, #ff8a65);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
    }
</style>

<!-- Breadcrumb -->
<section class="background-light">
    <div class="container">
        <ul class="breadcrumb">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li><img src="~/assets/icons/right.svg" alt="chevron-right"></li>
            <li><span>Şifrə Dəyiş</span></li>
        </ul>
    </div>
</section>

<section class="pb-100">
    <div class="tf-spacing-style3"></div>
    <div class="container">
        <div style="display:grid;grid-template-columns:260px 1fr;gap:30px;align-items:start;">

            <!-- Sidebar -->
            <div class="dash-sidebar">
                <a asp-controller="UserProfil" asp-action="Index" class="dash-nav-item">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 15C15.3137 15 18 12.3137 18 9C18 5.68629 15.3137 3 12 3C8.68629 3 6 5.68629 6 9C6 12.3137 8.68629 15 12 15Z"/><path d="M3 20.25C4.81594 17.1122 8.11406 15 12 15C15.8859 15 19.1841 17.1122 21 20.25"/></svg>
                    Profil
                </a>
                <a asp-controller="UserListing" asp-action="Index" class="dash-nav-item">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 6H21"/><path d="M8 12H21"/><path d="M8 18H21"/><circle cx="3" cy="6" r="0.5"/><circle cx="3" cy="12" r="0.5"/><circle cx="3" cy="18" r="0.5"/></svg>
                    Elanlarım
                </a>
                <a asp-controller="Reviews" asp-action="Index" class="dash-nav-item">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
                    Rəylər
                </a>
                <a asp-controller="Message" asp-action="Index" class="dash-nav-item">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15C21 15.5304 20.7893 16.0391 20.4142 16.4142C20.0391 16.7893 19.5304 17 19 17H7L3 21V5C3 4.46957 3.21071 3.96086 3.58579 3.58579C3.96086 3.21071 4.46957 3 5 3H19C19.5304 3 20.0391 3.21071 20.4142 3.58579C20.7893 3.96086 21 4.46957 21 5V15Z"/></svg>
                    Mesajlar
                </a>
                <a asp-controller="ChangePassword" asp-action="Index" class="dash-nav-item active">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7C7 5.67 7.53 4.4 8.46 3.46C9.4 2.53 10.67 2 12 2C13.33 2 14.6 2.53 15.54 3.46C16.47 4.4 17 5.67 17 7V11"/></svg>
                    Şifrə Dəyiş
                </a>
            </div>

            <!-- Main Content -->
            <div>
                <div class="cp-card">
                    <div class="cp-lock-icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7C7 5.67 7.53 4.4 8.46 3.46C9.4 2.53 10.67 2 12 2C13.33 2 14.6 2.53 15.54 3.46C16.47 4.4 17 5.67 17 7V11"/>
                        </svg>
                    </div>
                    <h2 style="text-align:center;margin-bottom:8px;">Şifrə Dəyişdir</h2>
                    <p style="text-align:center;color:#6b7280;font-size:14px;margin-bottom:32px;">Hesabınızın təhlükəsizliyi üçün güclü şifrə istifadə edin</p>

                    @if (ViewBag.Success != null)
                    {
                        <div class="cp-alert cp-alert--success">
                            ✅ @ViewBag.Success
                        </div>
                    }
                    @if (ViewBag.Error != null)
                    {
                        <div class="cp-alert cp-alert--error">
                            ⚠️ @Html.Raw(ViewBag.Error)
                        </div>
                    }

                    <form method="post" asp-controller="ChangePassword" asp-action="Index">
                        @Html.AntiForgeryToken()

                        <div class="cp-form-group">
                            <label>Email</label>
                            <input type="email" value="@email" disabled />
                        </div>

                        <div class="cp-form-group">
                            <label>Köhnə Şifrə *</label>
                            <input type="password" name="oldPassword" placeholder="Mövcud şifrənizi daxil edin" required autocomplete="current-password" />
                        </div>

                        <div class="cp-form-group">
                            <label>Yeni Şifrə *</label>
                            <input type="password" name="newPassword" placeholder="Yeni şifrə (min. 8 simvol)" required minlength="8" autocomplete="new-password" />
                        </div>

                        <div class="cp-form-group">
                            <label>Yeni Şifrəni Təkrarla *</label>
                            <input type="password" name="retypeNewPassword" placeholder="Yeni şifrəni təkrarlayın" required minlength="8" autocomplete="new-password" />
                        </div>

                        <div style="background:#f9fafb;border-radius:10px;padding:14px 16px;margin-bottom:24px;">
                            <p style="font-size:12px;color:#6b7280;margin:0;">
                                🔒 Şifrə tələbləri: Minimum 8 simvol, ən azı 1 böyük hərf və 1 rəqəm
                            </p>
                        </div>

                        <button type="submit" class="btn btn-primary btn-large font-weight-600" style="width:100%;">
                            Şifrəni Yenilə
                        </button>
                    </form>
                </div>
            </div>

        </div>
    </div>
</section>
