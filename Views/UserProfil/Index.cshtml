@using Microsoft.AspNetCore.Identity
@inject UserManager<AppUser> UserManager

@{
    ViewData["Title"] = "Profil";
    var user = (AppUser)ViewBag.User;
    var role = (string)ViewBag.Role;
    var carCount = (int)ViewBag.CarCount;
    var initials = user.FullName.Length > 0 ? user.FullName[0].ToString().ToUpper() : "?";

    var badgeBg = role switch
    {
        "SuperAdmin" => "#7c3aed",
        "Admin" => "#2563eb",
        "Agent" => "#f59e0b",
        _ => "#6b7280"
    };
}

<style>
    /* ===== Dashboard Sidebar ===== */
    .dash-sidebar {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 24px 0;
        position: sticky;
        top: 100px;
    }
    .dash-sidebar .dash-nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 24px;
        font-size: 14px;
        font-weight: 500;
        color: #4b5563;
        text-decoration: none;
        transition: all 0.2s;
        border-left: 3px solid transparent;
    }
    .dash-sidebar .dash-nav-item:hover {
        background: #f9fafb;
        color: #1c1c1c;
    }
    .dash-sidebar .dash-nav-item.active {
        background: #fff5f2;
        color: #FF5722;
        border-left-color: #FF5722;
        font-weight: 600;
    }
    .dash-sidebar .dash-nav-item svg { flex-shrink: 0; }

    /* ===== Profile Card ===== */
    .profile-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 40px;
    }
    .profile-avatar {
        width: 96px;
        height: 96px;
        border-radius: 50%;
        background: linear-gradient(135deg, #FF5722, #ff8a65);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 36px;
        font-weight: 700;
        margin: 0 auto 16px;
        box-shadow: 0 4px 16px rgba(255,87,34,0.25);
    }
    .profile-role-badge {
        display: inline-block;
        padding: 4px 16px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        color: #fff;
    }
    .profile-stats {
        display: flex;
        gap: 24px;
        justify-content: center;
        margin: 24px 0;
    }
    .profile-stat {
        text-align: center;
        padding: 16px 24px;
        background: #f9fafb;
        border-radius: 12px;
        min-width: 120px;
    }
    .profile-stat-value {
        font-size: 24px;
        font-weight: 700;
        color: #1c1c1c;
    }
    .profile-stat-label {
        font-size: 12px;
        color: #9ca3af;
        margin-top: 4px;
    }

    .profile-form-group {
        margin-bottom: 20px;
    }
    .profile-form-group label {
        display: block;
        font-size: 13px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
    }
    .profile-form-group input {
        width: 100%;
        padding: 12px 16px;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        font-size: 14px;
        transition: border-color 0.2s;
        outline: none;
    }
    .profile-form-group input:focus {
        border-color: #FF5722;
    }
    .profile-form-group input[disabled] {
        background: #f3f4f6;
        color: #9ca3af;
    }

    @@media (max-width: 768px) {
        .dash-layout { grid-template-columns: 1fr !important; }
        .dash-sidebar { position: static; }
    }
</style>

<!-- Breadcrumb -->
<section class="background-light">
    <div class="container">
        <ul class="breadcrumb">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li><img src="~/assets/icons/right.svg" alt="chevron-right"></li>
            <li><span>Profil</span></li>
        </ul>
    </div>
</section>

<section class="pb-100">
    <div class="tf-spacing-style3"></div>
    <div class="container">
        <div class="dash-layout" style="display:grid;grid-template-columns:260px 1fr;gap:30px;align-items:start;">

            <!-- Sidebar -->
            <div class="dash-sidebar">
                <a asp-controller="UserProfil" asp-action="Index" class="dash-nav-item active">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 15C15.3137 15 18 12.3137 18 9C18 5.68629 15.3137 3 12 3C8.68629 3 6 5.68629 6 9C6 12.3137 8.68629 15 12 15Z"/><path d="M3 20.25C4.81594 17.1122 8.11406 15 12 15C15.8859 15 19.1841 17.1122 21 20.25"/></svg>
                    Profil
                </a>
                <a asp-controller="UserListing" asp-action="Index" class="dash-nav-item">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 6H21"/><path d="M8 12H21"/><path d="M8 18H21"/><circle cx="3" cy="6" r="0.5"/><circle cx="3" cy="12" r="0.5"/><circle cx="3" cy="18" r="0.5"/></svg>
                    Elanlarım
                </a>
                <a asp-controller="Reviews" asp-action="Index" class="dash-nav-item">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
                    Rəylər
                </a>
                <a asp-controller="Message" asp-action="Index" class="dash-nav-item">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15C21 15.5304 20.7893 16.0391 20.4142 16.4142C20.0391 16.7893 19.5304 17 19 17H7L3 21V5C3 4.46957 3.21071 3.96086 3.58579 3.58579C3.96086 3.21071 4.46957 3 5 3H19C19.5304 3 20.0391 3.21071 20.4142 3.58579C20.7893 3.96086 21 4.46957 21 5V15Z"/></svg>
                    Mesajlar
                </a>
                <a asp-controller="ChangePassword" asp-action="Index" class="dash-nav-item">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7C7 5.67 7.53 4.4 8.46 3.46C9.4 2.53 10.67 2 12 2C13.33 2 14.6 2.53 15.54 3.46C16.47 4.4 17 5.67 17 7V11"/></svg>
                    Şifrə Dəyiş
                </a>
            </div>

            <!-- Main Content -->
            <div>

                @* ── Toast Bildirişləri ── *@
                @if (TempData["AuthSuccess"] != null)
                {
                    <div style="background:#f0fdf4;border:1px solid #86efac;border-radius:12px;
                                padding:14px 18px;margin-bottom:20px;display:flex;align-items:center;gap:10px;">
                        <span style="font-size:18px;">✅</span>
                        <span style="color:#166534;font-size:14px;font-weight:500;">@TempData["AuthSuccess"]</span>
                    </div>
                }
                @if (TempData["AuthError"] != null)
                {
                    <div style="background:#fef2f2;border:1px solid #fca5a5;border-radius:12px;
                                padding:14px 18px;margin-bottom:20px;display:flex;align-items:center;gap:10px;">
                        <span style="font-size:18px;">❌</span>
                        <span style="color:#991b1b;font-size:14px;font-weight:500;">@TempData["AuthError"]</span>
                    </div>
                }
                @if (TempData["AuthInfo"] != null)
                {
                    <div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:12px;
                                padding:14px 18px;margin-bottom:20px;display:flex;align-items:center;gap:10px;">
                        <span style="font-size:18px;">ℹ️</span>
                        <span style="color:#1d4ed8;font-size:14px;font-weight:500;">@TempData["AuthInfo"]</span>
                    </div>
                }

                <!-- Profile Info Card -->
                <div class="profile-card" style="text-align:center;margin-bottom:30px;">
                    <div class="profile-avatar">@initials</div>
                    <h2 style="margin-bottom:4px;">@user.FullName</h2>
                    <p style="color:#6b7280;font-size:14px;margin-bottom:12px;">@user.Email</p>
                    <span class="profile-role-badge" style="background:@badgeBg;">@role</span>

                    <div class="profile-stats">
                        <div class="profile-stat">
                            <div class="profile-stat-value">@carCount</div>
                            <div class="profile-stat-label">Elan sayı</div>
                        </div>
                        <div class="profile-stat">
                            <div class="profile-stat-value">@user.CreatedDate.ToString("dd MMM")</div>
                            <div class="profile-stat-label">Qeydiyyat</div>
                        </div>
                    </div>
                </div>

                <!-- Edit Profile Form -->
                <div class="profile-card">
                    <h3 style="margin-bottom:24px;font-size:18px;">Profili Yenilə</h3>

                    <form asp-controller="UserProfil" asp-action="UpdateProfile" method="post">
                        @Html.AntiForgeryToken()

                        <div class="profile-form-group">
                            <label>Email</label>
                            <input type="email" value="@user.Email" disabled />
                        </div>

                        <div class="profile-form-group">
                            <label>Ad Soyad</label>
                            <input type="text" name="fullName" value="@user.FullName" placeholder="Ad Soyadınız" required />
                        </div>

                        <div class="profile-form-group">
                            <label>Telefon Nömrəsi</label>
                            <input type="tel" name="phoneNumber" value="@user.PhoneNumber" placeholder="+994 XX XXX XX XX" />
                        </div>

                        <button type="submit" class="btn btn-primary btn-large font-weight-600" style="width:100%;">
                            Yadda Saxla
                        </button>
                    </form>
                </div>
            </div>

        </div>
    </div>
</section>
