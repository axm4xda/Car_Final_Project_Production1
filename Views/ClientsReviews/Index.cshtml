@model Car_Project.ViewModels.ClientsReviews.ClientsReviewsIndexViewModel

<!-- breadcrumb -->
<section class="background-light mb-32">
    <div class="container">
        <ul class="breadcrumb">
            <li>
                <a href="/">Home</a>
            </li>
            <li>
                <img src="/assets/icons/right.svg" alt="chevron-right">
            </li>
            <li>
                <span>Pages</span>
            </li>
            <li>
                <img src="/assets/icons/right.svg" alt="chevron-right">
            </li>
            <li>
                <span>Clients Reviews</span>
            </li>
        </ul>
    </div>
</section>
<!-- breadcrumb -->

<!-- Clients Reviews -->
<section class="pb-100">
    <div class="container">
        <h2>Clients Reviews</h2>

        @if (Model.TotalCount > 0)
        {
            <p class="mb-8 text-muted">
                <strong>@Model.TotalCount</strong> rəy &nbsp;|&nbsp;
                Ortalama reytinq:
                @for (int s = 1; s <= 5; s++)
                {
                    if (s <= Math.Round(Model.AverageRating))
                    {
                        <img src="/assets/icons/star-6.svg" alt="star" style="width:16px;display:inline;">
                    }
                    else
                    {
                        <img src="/assets/icons/star-5.svg" alt="star" style="width:16px;display:inline;">
                    }
                }
                <span>(@Model.AverageRating.ToString("0.0"))</span>
            </p>
        }

        <div class="tf-spacing-style3"></div>

        @if (Model.Reviews.Count == 0)
        {
            <div class="text-center py-60">
                <p class="text-muted">Hələ heç bir rəy yoxdur.</p>
            </div>
        }
        else
        {
            <div class="grid grid-cols-3 gap-y-38 gap-x-30 lg-grid-cols-2 md-grid-cols-1 mb-40">
                @foreach (var review in Model.Reviews)
                {
                    <div class="testimonior-box">
                        <!-- Ulduzlar -->
                        <div class="flex items-center gap-4 mb-16">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= review.Rating)
                                {
                                    <img src="/assets/icons/star-6.svg" alt="star">
                                }
                                else
                                {
                                    <img src="/assets/icons/star-5.svg" alt="star">
                                }
                            }
                        </div>

                        <!-- Rəy mətni -->
                        <p class="testimonior-box--desc mb-16">
                            @review.Content
                        </p>

                        <!-- Müəllif -->
                        <div class="testimonior-box--user">
                            @if (!string.IsNullOrEmpty(review.AvatarUrl))
                            {
                                <img class="testimonior--img" src="@review.AvatarUrl" alt="@review.AuthorName">
                            }
                            else
                            {
                                <img class="testimonior--img" src="/assets/images/avatar/avatar-4.png" alt="@review.AuthorName">
                            }
                            <div class="testimonior-box--user-content">
                                <p class="h5 title">@review.AuthorName</p>
                                @if (!string.IsNullOrEmpty(review.AuthorTitle))
                                {
                                    <p class="desc">@review.AuthorTitle</p>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <ul class="pagination justify-center">
                    @* Əvvəlki səhifə *@
                    @if (Model.CurrentPage > 1)
                    {
                        <li>
                            <a href="?page=@(Model.CurrentPage - 1)" class="pagination__link">
                                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M5.8075 9.5577L12.0575 3.3077C12.1736 3.19042 12.3326 3.12454 12.4985 3.12454C12.6643 3.12454 12.8234 3.19042 12.9407 3.3077C13.058 3.42498 13.1238 3.58404 13.1238 3.7499C13.1238 3.91575 13.058 4.07481 12.9407 4.19209L7.13199 9.9999L12.9407 15.8077C13.058 15.925 13.1238 16.084 13.1238 16.2499C13.1238 16.4157 13.058 16.5748 12.9407 16.6921C12.8234 16.8093 12.6643 16.8752 12.4985 16.8752C12.3326 16.8752 12.1736 16.8093 12.0575 16.6921L5.8075 10.4421C5.6902 10.3248 5.62427 10.1657 5.62427 9.9999C5.62427 9.83404 5.6902 9.67498 5.8075 9.5577Z" fill="#9FA1A4" />
                                </svg>
                            </a>
                        </li>
                    }

                    @* Səhifə nömrələri *@
                    @for (int p = 1; p <= Model.TotalPages; p++)
                    {
                        <li>
                            <a href="?page=@p" class="pagination__link @(p == Model.CurrentPage ? "active" : "")">
                                @p
                            </a>
                        </li>
                    }

                    @* Növbəti səhifə *@
                    @if (Model.CurrentPage < Model.TotalPages)
                    {
                        <li>
                            <a href="?page=@(Model.CurrentPage + 1)" class="pagination__link">
                                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M14.1925 10.4423L7.94254 16.6923C7.88447 16.7504 7.81553 16.7964 7.73966 16.8278C7.66379 16.8593 7.58247 16.8755 7.50035 16.8755C7.41823 16.8755 7.33691 16.8593 7.26104 16.8278C7.18517 16.7964 7.11623 16.7504 7.05816 16.6923C7.00009 16.6342 6.95403 16.5653 6.9226 16.4894C6.89117 16.4135 6.875 16.3322 6.875 16.2501C6.875 16.168 6.89117 16.0867 6.9226 16.0108C6.95403 15.9349 7.00009 15.866 7.05816 15.8079L12.8668 10.0001L7.05816 4.19229C6.94088 4.07502 6.875 3.91596 6.875 3.7501C6.875 3.58425 6.94088 3.42519 7.05816 3.30792C7.17544 3.19064 7.3345 3.12476 7.50035 3.12476C7.6662 3.12476 7.82526 3.19064 7.94254 3.30792L14.1925 9.55791C14.2506 9.61596 14.2967 9.68489 14.3282 9.76077C14.3597 9.83664 14.3758 9.91797 14.3758 10.0001C14.3758 10.0822 14.3597 10.1636 14.3282 10.2394C14.2967 10.3153 14.2506 10.3842 14.1925 10.4423Z" fill="#9FA1A4" />
                                </svg>
                            </a>
                        </li>
                    }
                </ul>
            }
        }
    </div>
</section>
<!-- Clients Reviews -->