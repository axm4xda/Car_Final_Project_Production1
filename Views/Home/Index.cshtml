@section Scripts {
<script>
// ====== Wishlist Heart (AJAX) ======
$(document).on('click', '.heart', function(e) {
    e.preventDefault();
    e.stopImmediatePropagation();
    var $btn = $(this);
    var carId = $btn.data('car-id');
    if (!carId) return;

    $.ajax({
        type: 'POST',
        url: '/Wishlist/Toggle/' + carId,
        headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').first().val()
        },
        success: function(res) {
            if (res.success) {
                $('.heart[data-car-id="' + carId + '"]').toggleClass('active', res.isInWishlist);
                updateNavBadge('#wishlistNavCount', res.count);
                showToast(res.isInWishlist ? 'Added to wishlist!' : 'Removed from wishlist.', 'success');
            }
        },
        error: function() { showToast('Error updating wishlist.', 'error'); }
    });
});

// ====== Compare Button (AJAX) ======
$(document).on('click', '.compare-details', function(e) {
    e.preventDefault();
    e.stopImmediatePropagation();
    var $btn = $(this);
    var carId = $btn.data('car-id');
    if (!carId) return;

    if ($btn.hasClass('active')) {
        $.ajax({
            type: 'POST',
            url: '/Compare/Remove/' + carId,
            headers: {
                'X-Requested-With': 'XMLHttpRequest',
                'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').first().val()
            },
            success: function(res) {
                if (res.success) {
                    $btn.removeClass('active');
                    updateNavBadge('#compareNavCount', res.count);
                    showToast('Removed from compare.', 'success');
                }
            },
            error: function() { showToast('Error removing from compare.', 'error'); }
        });
        return;
    }

    $.ajax({
        type: 'POST',
        url: '/Compare/Add/' + carId,
        headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').first().val()
        },
        success: function(res) {
            if (res.success) {
                $btn.addClass('active');
                updateNavBadge('#compareNavCount', res.count);
                showToast('Added to compare!', 'success');
            } else {
                showToast(res.message || 'Could not add to compare.', 'error');
            }
        },
        error: function() { showToast('Error adding to compare.', 'error'); }
    });
});

// ====== Helpers ======
function updateNavBadge(selector, count) {
    var $badge = $(selector);
    if (count > 0) {
        $badge.text(count).show();
    } else {
        $badge.text('0').hide();
    }
}

function showToast(msg, type) {
    var existing = $('#action-toast');
    if (existing.length) existing.remove();
    var cls = type === 'success' ? 'auth-toast--success' : 'auth-toast--error';
    var $toast = $('<div id="action-toast" class="auth-toast ' + cls + '"><span>' + msg + '</span><button onclick="$(\'#action-toast\').remove()">✕</button></div>');
    $('body').append($toast);
    setTimeout(function() { $toast.fadeOut(300, function() { $(this).remove(); }); }, 3000);
}
</script>
}