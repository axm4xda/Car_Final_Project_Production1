@{
    ViewData["Title"] = "Elanlarım";
    var cars = (List<Car>)ViewBag.Cars;
    var currentPage = (int)ViewBag.CurrentPage;
    var totalPages = (int)ViewBag.TotalPages;
    var totalCount = (int)ViewBag.TotalCount;
    var searchQuery = (string?)ViewBag.SearchQuery;
    var selectedSort = (string)ViewBag.SelectedSort;
}

<style>
    .dash-sidebar {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 24px 0;
        position: sticky;
        top: 100px;
    }
    .dash-sidebar .dash-nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 24px;
        font-size: 14px;
        font-weight: 500;
        color: #4b5563;
        text-decoration: none;
        transition: all 0.2s;
        border-left: 3px solid transparent;
    }
    .dash-sidebar .dash-nav-item:hover { background: #f9fafb; color: #1c1c1c; }
    .dash-sidebar .dash-nav-item.active { background: #fff5f2; color: #FF5722; border-left-color: #FF5722; font-weight: 600; }
    .dash-sidebar .dash-nav-item svg { flex-shrink: 0; }

    /* Toolbar */
    .ul-toolbar {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 20px 24px;
        margin-bottom: 24px;
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        align-items: center;
    }
    .ul-toolbar select, .ul-toolbar input {
        padding: 10px 14px;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        font-size: 13px;
        outline: none;
        transition: border-color 0.2s;
    }
    .ul-toolbar select:focus, .ul-toolbar input:focus { border-color: #FF5722; }
    .ul-toolbar .ul-count {
        font-size: 14px;
        color: #6b7280;
        margin-left: auto;
    }

    /* Car Card */
    .ul-car-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        overflow: hidden;
        display: flex;
        gap: 0;
        transition: box-shadow 0.2s, transform 0.2s;
    }
    .ul-car-card:hover {
        box-shadow: 0 8px 24px rgba(0,0,0,0.08);
        transform: translateY(-2px);
    }
    .ul-car-img {
        width: 240px;
        min-height: 180px;
        object-fit: cover;
        flex-shrink: 0;
        background: #f3f4f6;
    }
    .ul-car-body {
        padding: 20px 24px;
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }
    .ul-car-badge {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 600;
        color: #fff;
    }
    .ul-car-title {
        font-size: 16px;
        font-weight: 600;
        color: #1c1c1c;
        margin: 8px 0 4px;
    }
    .ul-car-specs {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        margin-top: 8px;
    }
    .ul-car-spec {
        display: flex;
        align-items: center;
        gap: 4px;
        font-size: 12px;
        color: #6b7280;
    }
    .ul-car-price {
        font-size: 20px;
        font-weight: 700;
        color: #FF5722;
    }
    .ul-car-actions {
        display: flex;
        gap: 8px;
        align-items: center;
    }
    .ul-btn-delete {
        background: #fef2f2;
        color: #dc2626;
        border: 1px solid #fecaca;
        border-radius: 10px;
        padding: 8px 16px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }
    .ul-btn-delete:hover { background: #dc2626; color: #fff; }
    .ul-btn-view {
        background: #f3f4f6;
        color: #374151;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 8px 16px;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
    }
    .ul-btn-view:hover { background: #FF5722; color: #fff; border-color: #FF5722; }

    /* Pagination */
    .ul-pagination {
        display: flex;
        justify-content: center;
        gap: 8px;
        margin-top: 32px;
    }
    .ul-pagination a, .ul-pagination span {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 40px;
        height: 40px;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s;
    }
    .ul-pagination a {
        background: #fff;
        color: #374151;
        border: 1px solid #e5e7eb;
    }
    .ul-pagination a:hover { border-color: #FF5722; color: #FF5722; }
    .ul-pagination .active {
        background: #FF5722;
        color: #fff;
        border: 1px solid #FF5722;
    }
    .ul-empty {
        text-align: center;
        padding: 60px 20px;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
    }
    .ul-empty-icon {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: #f3f4f6;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
        font-size: 28px;
    }
</style>

<!-- Breadcrumb -->
<section class="background-light">
    <div class="container">
        <ul class="breadcrumb">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li><img src="~/assets/icons/right.svg" alt="chevron-right"></li>
            <li><span>Elanlarım</span></li>
        </ul>
    </div>
</section>

<section class="pb-100">
    <div class="tf-spacing-style3"></div>
    <div class="container">
        <div style="display:grid;grid-template-columns:260px 1fr;gap:30px;align-items:start;">

            <!-- Sidebar -->
            <div class="dash-sidebar">
                <a asp-controller="UserProfil" asp-action="Index" class="dash-nav-item">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 15C15.3137 15 18 12.3137 18 9C18 5.68629 15.3137 3 12 3C8.68629 3 6 5.68629 6 9C6 12.3137 8.68629 15 12 15Z"/><path d="M3 20.25C4.81594 17.1122 8.11406 15 12 15C15.8859 15 19.1841 17.1122 21 20.25"/></svg>
                    Profil
                </a>
                <a asp-controller="UserListing" asp-action="Index" class="dash-nav-item active">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 6H21"/><path d="M8 12H21"/><path d="M8 18H21"/><circle cx="3" cy="6" r="0.5"/><circle cx="3" cy="12" r="0.5"/><circle cx="3" cy="18" r="0.5"/></svg>
                    Elanlarım
                </a>
                <a asp-controller="Reviews" asp-action="Index" class="dash-nav-item">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
                    Rəylər
                </a>
                <a asp-controller="Message" asp-action="Index" class="dash-nav-item">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15C21 15.5304 20.7893 16.0391 20.4142 16.4142C20.0391 16.7893 19.5304 17 19 17H7L3 21V5C3 4.46957 3.21071 3.96086 3.58579 3.58579C3.96086 3.21071 4.46957 3 5 3H19C19.5304 3 20.0391 3.21071 20.4142 3.58579C20.7893 3.96086 21 4.46957 21 5V15Z"/></svg>
                    Mesajlar
                </a>
                <a asp-controller="ChangePassword" asp-action="Index" class="dash-nav-item">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7C7 5.67 7.53 4.4 8.46 3.46C9.4 2.53 10.67 2 12 2C13.33 2 14.6 2.53 15.54 3.46C16.47 4.4 17 5.67 17 7V11"/></svg>
                    Şifrə Dəyiş
                </a>
            </div>

            <!-- Main Content -->
            <div>
                <!-- Toolbar -->
                <form asp-controller="UserListing" asp-action="Index" method="get" class="ul-toolbar">
                    <input type="text" name="search" value="@searchQuery" placeholder="🔍 Elan axtar..." style="min-width:200px;flex:1;" />

                    <select name="sort" onchange="this.form.submit()">
                        <option value="newest" selected="@(selectedSort == "newest")">Ən yeni</option>
                        <option value="lowest-price" selected="@(selectedSort == "lowest-price")">Ən aşağı qiymət</option>
                        <option value="highest-price" selected="@(selectedSort == "highest-price")">Ən yüksək qiymət</option>
                        <option value="lowest-mileage" selected="@(selectedSort == "lowest-mileage")">Ən az yürüş</option>
                        <option value="highest-mileage" selected="@(selectedSort == "highest-mileage")">Ən çox yürüş</option>
                    </select>

                    <button type="submit" class="btn btn-primary btn-medium font-weight-600">Axtar</button>

                    <a asp-controller="AddListing" asp-action="Index" class="btn btn-primary btn-medium font-weight-600" style="text-decoration:none;">+ Yeni Elan</a>

                    <span class="ul-count">@totalCount elan tapıldı</span>
                </form>

                @if (cars.Any())
                {
                    <div style="display:flex;flex-direction:column;gap:16px;">
                        @foreach (var car in cars)
                        {
                            var mainImage = car.Images.FirstOrDefault(i => i.IsMain)?.ImageUrl
                                            ?? car.Images.FirstOrDefault()?.ImageUrl
                                            ?? car.ThumbnailUrl
                                            ?? "/assets/images/car-placeholder.png";

                            <div class="ul-car-card">
                                <img src="@mainImage" alt="@car.Title" class="ul-car-img" />
                                <div class="ul-car-body">
                                    <div>
                                        @if (car.IsApproved)
                                        {
                                            <span class="ul-car-badge" style="background:#16a34a">✓ Təsdiqləndi</span>
                                        }
                                        else
                                        {
                                            <span class="ul-car-badge" style="background:#f59e0b">⏳ Gözləyir</span>
                                        }

                                        @if (!string.IsNullOrEmpty(car.Badge))
                                        {
                                            <span class="ul-car-badge" style="background:@(car.BadgeColor ?? "#FF5722")">@car.Badge</span>
                                        }
                                        <h3 class="ul-car-title">@car.Title</h3>
                                        <p style="font-size:13px;color:#9ca3af;margin:0;">@car.Brand?.Name · @car.Year</p>

                                        <div class="ul-car-specs">
                                            <span class="ul-car-spec">⛽ @car.FuelType</span>
                                            <span class="ul-car-spec">⚙️ @car.Transmission</span>
                                            <span class="ul-car-spec">🛣️ @car.Mileage.ToString("N0") km</span>
                                            <span class="ul-car-spec">📋 @car.Condition</span>
                                        </div>
                                    </div>

                                    <div style="display:flex;align-items:center;justify-content:space-between;margin-top:16px;">
                                        <span class="ul-car-price">$@car.Price.ToString("N0")</span>
                                        <div class="ul-car-actions">
                                            <a asp-controller="List" asp-action="Detail" asp-route-id="@car.Id" class="ul-btn-view">
                                                👁️ Bax
                                            </a>
                                            <form asp-controller="UserListing" asp-action="Delete" method="post" style="display:inline;"
                                                  onsubmit="return confirm('Bu elanı silmək istədiyinizə əminsiniz?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@car.Id" />
                                                <button type="submit" class="ul-btn-delete">🗑️ Sil</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Pagination -->
                    @if (totalPages > 1)
                    {
                        <div class="ul-pagination">
                            @if (currentPage > 1)
                            {
                                <a asp-controller="UserListing" asp-action="Index"
                                   asp-route-page="@(currentPage - 1)"
                                   asp-route-search="@searchQuery"
                                   asp-route-sort="@selectedSort">‹</a>
                            }

                            @for (int i = 1; i <= totalPages; i++)
                            {
                                if (i == currentPage)
                                {
                                    <span class="active">@i</span>
                                }
                                else
                                {
                                    <a asp-controller="UserListing" asp-action="Index"
                                       asp-route-page="@i"
                                       asp-route-search="@searchQuery"
                                       asp-route-sort="@selectedSort">@i</a>
                                }
                            }

                            @if (currentPage < totalPages)
                            {
                                <a asp-controller="UserListing" asp-action="Index"
                                   asp-route-page="@(currentPage + 1)"
                                   asp-route-search="@searchQuery"
                                   asp-route-sort="@selectedSort">›</a>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="ul-empty">
                        <div class="ul-empty-icon">🚗</div>
                        <h3 style="margin-bottom:8px;">Elan tapılmadı</h3>
                        <p style="color:#6b7280;font-size:14px;margin-bottom:20px;">Hələ heç bir elan paylaşmamısınız</p>
                        <a asp-controller="AddListing" asp-action="Index" class="btn btn-primary btn-medium font-weight-600">
                            + Yeni Elan Yarat
                        </a>
                    </div>
                }
            </div>

        </div>
    </div>
</section>
