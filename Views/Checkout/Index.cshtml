@model Car_Project.ViewModels.Checkout.CheckoutPageViewModel
@using Car_Project.Models
@{
    ViewData["Title"] = "Check Out";
}

<!-- ── Payment Loading Overlay ── -->
<div id="paymentLoadingOverlay" style="display:none;position:fixed;inset:0;z-index:999999;background:rgba(0,0,0,0.55);backdrop-filter:blur(3px);flex-direction:column;align-items:center;justify-content:center;gap:24px;">
    <div style="background:#fff;border-radius:20px;padding:40px 48px;text-align:center;box-shadow:0 12px 48px rgba(0,0,0,0.2);max-width:340px;width:90%;">
        <!-- Animated spinner -->
        <div style="width:72px;height:72px;border-radius:50%;border:5px solid #f3f4f6;border-top-color:#FF5722;animation:paySpinner 0.9s linear infinite;margin:0 auto 20px;"></div>
        <h3 style="margin:0 0 8px;font-size:20px;font-weight:700;color:#1c1c1c;">Processing Payment</h3>
        <p style="margin:0;font-size:14px;color:#6b7280;line-height:1.6;">Please wait while we securely process your payment. Do not close this window.</p>
        <!-- Progress bar -->
        <div style="margin-top:20px;height:6px;background:#f3f4f6;border-radius:99px;overflow:hidden;">
            <div id="payProgressBar" style="height:100%;width:0%;background:linear-gradient(90deg,#FF5722,#ff7043);border-radius:99px;transition:width 0.2s linear;"></div>
        </div>
    </div>
</div>

<style>
    @@keyframes paySpinner {
        to { transform: rotate(360deg); }
    }
</style>

<!-- breadcrumb -->
<section class="background-light">
    <div class="container">
        <ul class="breadcrumb">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li><img src="~/assets/icons/right.svg" alt="chevron-right"></li>
            <li><span>Check Out</span></li>
        </ul>
    </div>
</section>

<!-- Checkout -->
<section class="bg-white shopping-cart-page">
    <div class="container">

        <form asp-controller="Checkout" asp-action="PlaceOrder" method="post" class="w-full" id="checkoutForm">
            @Html.AntiForgeryToken()
            <div class="checkout-container">

                <!-- ─── LEFT: Billing + Payment ─────────────────────────── -->
                <div class="left">
                    <h2>Check Out</h2>
                    <div class="tf-spacing-style3"></div>

                    <!-- Validation Summary -->
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger mb-20">
                            <ul>
                                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <li>@error.ErrorMessage</li>
                                }
                            </ul>
                        </div>
                    }

                    <p class="h4 mb-20">Billing Details:</p>

                    <div class="grid grid-cols-2 md-grid-cols-1 gap-16 mb-35">
                        <input class="input-large mb-6 md-col-span-2" type="text"
                               placeholder="First Name*" name="Form.FirstName"
                               value="@Model.Form.FirstName" required>

                        <input class="input-large mb-6 md-col-span-2" type="text"
                               placeholder="Last Name*" name="Form.LastName"
                               value="@Model.Form.LastName" required>

                        <input class="input-large mb-6 md-col-span-2" type="email"
                               placeholder="Email Address*" name="Form.Email"
                               value="@Model.Form.Email" required>

                        <input class="input-large mb-6 md-col-span-2" type="text"
                               placeholder="Phone Number*" name="Form.Phone"
                               value="@Model.Form.Phone" required>

                        <div class="mb-6 col-span-2 padding-0">
                            <div class="custom-select" data-target="#country">
                                <div class="select-selected select--black" tabindex="0">
                                    @(string.IsNullOrEmpty(Model.Form.Country) ? "Choose Country/Region" : Model.Form.Country)
                                </div>
                                <div class="select-items">
                                    <div data-value="Canada">Canada</div>
                                    <div data-value="USA">USA</div>
                                    <div data-value="Viet Nam">Viet Nam</div>
                                </div>
                            </div>
                            <input type="hidden" id="country" name="Form.Country" value="@Model.Form.Country">
                        </div>

                        <input class="input-large mb-6 md-col-span-2" type="text"
                               placeholder="Town/City*" name="Form.City"
                               value="@Model.Form.City" required>

                        <input class="input-large mb-6 md-col-span-2" type="text"
                               placeholder="Street,..." name="Form.Street"
                               value="@Model.Form.Street">

                        <div class="mb-6 padding-0">
                            <div class="custom-select" data-target="#state">
                                <div class="select-selected select--black" tabindex="0">
                                    @(string.IsNullOrEmpty(Model.Form.State) ? "Choose State" : Model.Form.State)
                                </div>
                                <div class="select-items">
                                    <div data-value="Ontario">Ontario</div>
                                    <div data-value="Quebec">Quebec</div>
                                    <div data-value="California">California</div>
                                </div>
                            </div>
                            <input type="hidden" id="state" name="Form.State" value="@Model.Form.State">
                        </div>

                        <input class="input-large mb-6 md-col-span-2" type="text"
                               placeholder="Postal Code*" name="Form.PostalCode"
                               value="@Model.Form.PostalCode" required>

                        <div class="col-span-2 padding-0">
                            <textarea placeholder="Write note..." rows="3" name="Form.Note"
                                      class="message">@Model.Form.Note</textarea>
                        </div>
                    </div>

                    <p class="h4 capitalize mb-20">Choose payment Option:</p>
                    <input type="hidden" name="Form.PaymentMethod" id="selectedPaymentMethod"
                           value="@((int)Model.Form.PaymentMethod)">

                    <div class="flat-accordion style-2 flex flex-col gap-20 max-width-930 wow fadeIn mb-40" data-wow-delay=".3s">

                        <!-- Credit Card -->
                        <div class="flat-toggle active bg-white">
                            <div class="toggle-title active">
                                <div class="filter-radio">
                                    <input type="radio" name="paymentChoice" value="@((int)PaymentMethod.CreditCard)"
                                           @(Model.Form.PaymentMethod == PaymentMethod.CreditCard ? "checked" : "")
                                           onchange="document.getElementById('selectedPaymentMethod').value=this.value">
                                    <div class="label-focus">
                                        <div class="flex items-center gap-8 font-weight-600">Credit Card</div>
                                    </div>
                                </div>
                                <span class="icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M20 15L12 7L4 15" stroke="#1C1C1C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                </span>
                            </div>
                            <div class="toggle-content">
                                <p class="mb-20 text-secondary">
                                    Make your payment directly into our bank account.
                                </p>
                                <div class="grid grid-cols-2 lg-grid-cols-1 gap-16">
                                    <div class="col-span-2 padding-0">
                                        <input class="input-large mb-6" type="text"
                                               placeholder="Name On Card*" name="Form.CardHolderName"
                                               value="@Model.Form.CardHolderName">
                                    </div>
                                    <div class="relative col-span-2 padding-0 input-payment-wrapper">
                                        <input class="input-large mb-6" type="text"
                                               placeholder="Card Numbers*" name="Form.CardNumber"
                                               value="@Model.Form.CardNumber">
                                        <img class="payment h-16" src="~/assets/icons/Payment.png" alt="Payment">
                                    </div>
                                    <div class="mb-8 col-span-2 padding-0 grid grid-cols-2 lg-grid-cols-1 gap-16">
                                        <input class="input-large" type="text"
                                               placeholder="mm/yy*" name="Form.CardExpiry"
                                               value="@Model.Form.CardExpiry">
                                        <input class="input-large" type="text"
                                               placeholder="CVV*" name="Form.CardCvv"
                                               value="@Model.Form.CardCvv">
                                    </div>
                                    <label class="filter-checkbox style-5">
                                        <input type="checkbox" name="saveCard" value="1">
                                        <span>save card</span>
                                    </label>
                                </div>
                            </div>
                        </div>

                        <!-- Cash on Delivery -->
                        <div class="flat-toggle bg-white">
                            <div class="toggle-title">
                                <div class="filter-radio">
                                    <input type="radio" name="paymentChoice" value="@((int)PaymentMethod.CashOnDelivery)"
                                           @(Model.Form.PaymentMethod == PaymentMethod.CashOnDelivery ? "checked" : "")
                                           onchange="document.getElementById('selectedPaymentMethod').value=this.value">
                                    <div class="label-focus">
                                        <div class="flex items-center gap-8 font-weight-600">Cash on delivery</div>
                                    </div>
                                </div>
                                <span class="icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M20 15L12 7L4 15" stroke="#1C1C1C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                </span>
                            </div>
                            <div class="toggle-content">
                                <p class="mb-20 text-secondary">
                                    Pay with cash upon delivery of your order.
                                </p>
                            </div>
                        </div>

                        <!-- Apple Pay -->
                        <div class="flat-toggle bg-white">
                            <div class="toggle-title">
                                <div class="filter-radio">
                                    <input type="radio" name="paymentChoice" value="@((int)PaymentMethod.ApplePay)"
                                           @(Model.Form.PaymentMethod == PaymentMethod.ApplePay ? "checked" : "")
                                           onchange="document.getElementById('selectedPaymentMethod').value=this.value">
                                    <div class="label-focus">
                                        <div class="flex items-center gap-8 font-weight-600">
                                            <img src="~/assets/icons/ApplePay.svg" alt="Apple Pay">
                                            Apple Pay
                                        </div>
                                    </div>
                                </div>
                                <span class="icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M20 15L12 7L4 15" stroke="#1C1C1C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                </span>
                            </div>
                            <div class="toggle-content">
                                <p class="mb-20 text-secondary">Pay securely with Apple Pay.</p>
                            </div>
                        </div>

                        <!-- PayPal -->
                        <div class="flat-toggle bg-white">
                            <div class="toggle-title">
                                <div class="filter-radio h-full">
                                    <input type="radio" name="paymentChoice" value="@((int)PaymentMethod.PayPal)"
                                           @(Model.Form.PaymentMethod == PaymentMethod.PayPal ? "checked" : "")
                                           onchange="document.getElementById('selectedPaymentMethod').value=this.value">
                                    <div class="label-focus top-0">
                                        <img src="~/assets/icons/paypal.svg" alt="PayPal">
                                    </div>
                                </div>
                                <span class="icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M20 15L12 7L4 15" stroke="#1C1C1C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                </span>
                            </div>
                            <div class="toggle-content">
                                <p class="mb-20 text-secondary">Pay securely with PayPal.</p>
                            </div>
                        </div>

                    </div>

                    <button type="submit" id="placeOrderBtn" class="btn btn-primary btn-large w-full">
                        Place Order
                    </button>
                </div>

                <!-- ─── RIGHT: Order Summary ──────────────────────────────── -->
                <div class="right">
                    <div class="h-48 lg-hidden"></div>
                    <div class="tf-spacing-style3"></div>
                    <p class="h4 mb-30">Your Order</p>

                    <div class="your-order mb-20">
                        @foreach (var item in Model.Summary.Items)
                        {
                            <div class="order-item">
                                <div class="flex items-center gap-16">
                                    <img class="order-item-img"
                                         src="@(item.ThumbnailUrl ?? "~/assets/images/shop/product-1.jpg")"
                                         alt="@item.ProductName">
                                    <p class="font-weight-600">@item.ProductName</p>
                                </div>
                                <p class="font-weight-600">@item.Quantity X $@item.UnitPrice.ToString("F2")</p>
                            </div>
                        }
                    </div>

                    <!-- Coupon -->
                    <div class="cart-total style-2 flex justify-between gap-12 flex-col mb-12">
                        <div class="cart-total__voucher full">
                            <input type="text" class="input-large" name="Form.CouponCode"
                                   value="@Model.Form.CouponCode" placeholder="Add voucher discount">
                            <button type="button" class="btn btn-small-2 btn-primary"
                                    id="applyCouponBtn">Apply Coupon</button>
                        </div>
                    </div>

                    <p class="text-sm mb-30">
                        Discount code is only used for orders with a total value of products over $50.00
                    </p>

                    <div class="divider mb-20"></div>

                    <div class="flex justify-between gap-8 mb-16">
                        <p class="font-weight-600">Shipping</p>
                        <p class="text-secondary">@(Model.Summary.ShippingCost == 0 ? "Free" : "$" + Model.Summary.ShippingCost.ToString("F2"))</p>
                    </div>

                    <div class="flex justify-between gap-8 mb-20">
                        <p class="font-weight-600">Discounts</p>
                        <p class="text-secondary">-$@Model.Summary.Discount.ToString("F2")</p>
                    </div>

                    <div class="divider mb-20"></div>

                    <div class="flex justify-between gap-8 mb-20">
                        <p class="h4 font-weight-600">Total</p>
                        <p class="h4 text-secondary">$@Model.Summary.Total.ToString("F2")</p>
                    </div>
                </div>

            </div>
        </form>
    </div>
</section>

@section Scripts {
<script>
(function () {
    var form    = document.getElementById('checkoutForm');
    var overlay = document.getElementById('paymentLoadingOverlay');
    var bar     = document.getElementById('payProgressBar');
    var btn     = document.getElementById('placeOrderBtn');
    if (!form || !overlay) return;

    form.addEventListener('submit', function (e) {
        // Basic HTML5 validation check — if the form is invalid, let the browser handle it
        if (!form.checkValidity()) return;

        // Show overlay
        overlay.style.display = 'flex';
        btn.disabled = true;

        // Animate progress bar over 5 seconds (100% = form submits)
        var startTime = Date.now();
        var duration  = 5000; // 5 seconds
        var raf;

        function step() {
            var elapsed  = Date.now() - startTime;
            var progress = Math.min((elapsed / duration) * 100, 100);
            bar.style.width = progress + '%';
            if (progress < 100) {
                raf = requestAnimationFrame(step);
            }
            // at 100% the form has already been submitted by the browser
        }
        requestAnimationFrame(step);
        // The native form submit continues normally in the background
    });
})();
</script>
}
