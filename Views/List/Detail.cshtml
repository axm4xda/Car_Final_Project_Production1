@section Scripts {
<script>
// ====== Financing Calculator ======
document.addEventListener('DOMContentLoaded', function () {
    var btnCalc = document.getElementById('btnCalculateFinancing');
    if (!btnCalc) return;

    btnCalc.addEventListener('click', function () {
        var carPrice     = parseFloat(document.getElementById('FinancingCalculatorCarPrice').value)    || 0;
        var interestRate = parseFloat(document.getElementById('FinancingCalculatorInterestRate').value) || 0;
        var loanTerm     = parseInt(document.getElementById('FinancingCalculatorLoanTerm').value)       || 60;
        var downPayment  = parseFloat(document.getElementById('FinancingCalculatorDownPayment').value)  || 0;

        var principal = carPrice - downPayment;
        if (principal <= 0) { alert('Car price must be greater than down payment.'); return; }

        var monthlyRate = (interestRate / 100) / 12;
        var monthly;
        if (monthlyRate === 0) {
            monthly = principal / loanTerm;
        } else {
            monthly = principal * (monthlyRate * Math.pow(1 + monthlyRate, loanTerm))
                                / (Math.pow(1 + monthlyRate, loanTerm) - 1);
        }

        var totalLoan     = monthly * loanTerm;
        var totalInterest = totalLoan - principal;

        function fmt(n) { return '$' + n.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ','); }

        document.getElementById('calcMonthlyPayment').textContent = fmt(monthly) + '/mo';
        document.getElementById('calcTotalInterest').textContent  = fmt(totalInterest);
        document.getElementById('calcTotalLoan').textContent      = fmt(totalLoan);

        document.getElementById('financingResults').style.display = 'grid';

        // Update the full-calculator link with current values
        var goBtn = document.getElementById('btnGoToCalculator');
        goBtn.href = '/Calculator?carPrice=' + encodeURIComponent(carPrice)
            + '&downPayment=' + encodeURIComponent(downPayment)
            + '&loanTerm='    + encodeURIComponent(loanTerm)
            + '&interestRate='+ encodeURIComponent(interestRate);
    });
});

// ====== Star Rating Interactivity ======
document.addEventListener('DOMContentLoaded', function () {
    const stars     = document.querySelectorAll('.rating-input__star');
    const ratingVal = document.getElementById('rating-value');
    if (!stars.length || !ratingVal) return;

    const activeIcon   = '/assets/icons/star-4.svg';
    const inactiveIcon = '/assets/icons/star-3.svg';

    stars.forEach(function (star) {
        star.addEventListener('click', function () {
            const selected = parseInt(this.dataset.rating);
            ratingVal.value = selected;
            stars.forEach(function (s) {
                const r   = parseInt(s.dataset.rating);
                const img = s.querySelector('img');
                if (r <= selected) {
                    s.classList.add('active');
                    img.src = activeIcon;
                } else {
                    s.classList.remove('active');
                    img.src = inactiveIcon;
                }
            });
        });

        star.addEventListener('mouseenter', function () {
            const hovered = parseInt(this.dataset.rating);
            stars.forEach(function (s) {
                const r   = parseInt(s.dataset.rating);
                const img = s.querySelector('img');
                img.src   = r <= hovered ? activeIcon : inactiveIcon;
            });
        });

        star.addEventListener('mouseleave', function () {
            const current = parseInt(ratingVal.value);
            stars.forEach(function (s) {
                const r   = parseInt(s.dataset.rating);
                const img = s.querySelector('img');
                img.src   = r <= current ? activeIcon : inactiveIcon;
            });
        });
    });
});

// ====== Wishlist Heart (AJAX) ======
$(document).on('click', '.heart', function(e) {
    e.preventDefault();
    e.stopImmediatePropagation();
    var $btn = $(this);
    var carId = $btn.data('car-id');
    if (!carId) return;

    $.ajax({
        type: 'POST',
        url: '/Wishlist/Toggle/' + carId,
        headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').first().val()
        },
        success: function(res) {
            if (res.success) {
                $('.heart[data-car-id="' + carId + '"]').toggleClass('active', res.isInWishlist);
                updateNavBadge('#wishlistNavCount', res.count);
                showToast(res.isInWishlist ? 'Added to wishlist!' : 'Removed from wishlist.', 'success');
            }
        },
        error: function() { showToast('Error updating wishlist.', 'error'); }
    });
});

// ====== Compare Button (AJAX) ======
$(document).on('click', '.compare-details', function(e) {
    e.preventDefault();
    e.stopImmediatePropagation();
    var $btn = $(this);
    var carId = $btn.data('car-id');
    if (!carId) return;

    if ($btn.hasClass('active')) {
        $.ajax({
            type: 'POST',
            url: '/Compare/Remove/' + carId,
            headers: {
                'X-Requested-With': 'XMLHttpRequest',
                'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').first().val()
            },
            success: function(res) {
                if (res.success) {
                    $btn.removeClass('active');
                    updateNavBadge('#compareNavCount', res.count);
                    showToast('Removed from compare.', 'success');
                }
            },
            error: function() { showToast('Error removing from compare.', 'error'); }
        });
        return;
    }

    $.ajax({
        type: 'POST',
        url: '/Compare/Add/' + carId,
        headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').first().val()
        },
        success: function(res) {
            if (res.success) {
                $btn.addClass('active');
                updateNavBadge('#compareNavCount', res.count);
                showToast('Added to compare!', 'success');
            } else {
                showToast(res.message || 'Could not add to compare.', 'error');
            }
        },
        error: function() { showToast('Error adding to compare.', 'error'); }
    });
});

// ====== Helpers ======
function updateNavBadge(selector, count) {
    var $badge = $(selector);
    if (count > 0) {
        $badge.text(count).show();
    } else {
        $badge.text('0').hide();
    }
}

function showToast(msg, type) {
    var existing = $('#action-toast');
    if (existing.length) existing.remove();
    var cls = type === 'success' ? 'auth-toast--success' : 'auth-toast--error';
    var $toast = $('<div id="action-toast" class="auth-toast ' + cls + '"><span>' + msg + '</span><button onclick="$(\'#action-toast\').remove()">✕</button></div>');
    $('body').append($toast);
    setTimeout(function() { $toast.fadeOut(300, function() { $(this).remove(); }); }, 3000);
}

function toggleReplyForm(replyFormId) {
    var $form = $('#' + replyFormId);
    $form.toggle();
}
</script>
}