@inject Microsoft.AspNetCore.Identity.SignInManager<AppUser> SignInManager
@inject Microsoft.AspNetCore.Identity.UserManager<AppUser> UserManager
@inject Car_Project.Services.Abstractions.ICompareItemService CompareService
@inject Car_Project.Services.Abstractions.IWishlistService WishlistService
@inject Car_Project.Services.Abstractions.INotificationService NotificationService
<!DOCTYPE html>
<html lang="en">
<meta http-equiv="content-type" content="text/html;charset=utf-8" />
<head>
	<meta charset="UTF-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Aurexo | Car Dealer, Rental & Listing HTML Template</title>
	<link rel="stylesheet" href="~/assets/scss/swiper/swiper-bundle.min.css">
	<link rel="stylesheet" href="~/assets/app.css">
	<link rel="stylesheet" href="~/assets/css/custom.css">
	<meta property="og:image" content="~/assets/images/logo.png">
	<meta property="og:type" content="website">
	<!-- Favicon and Touch Icons  -->
	<link rel="shortcut icon" href="~/assets/images/favicon.png">
	<link rel="apple-touch-icon-precomposed" href="~/assets/images/favicon.png">

	<style>
		/* ===== User Dropdown ===== */
		.user-dropdown {
			position: relative;
			display: inline-flex;
		}
		.user-dropdown-toggle {
			display: inline-flex;
			align-items: center;
			gap: 8px;
			cursor: pointer;
			position: relative;
			background: transparent;
		}
		.user-dropdown-toggle .ud-chevron {
			width: 16px;
			height: 16px;
			transition: transform 0.25s ease;
			flex-shrink: 0;
		}
		.user-dropdown:hover .ud-chevron,
		.user-dropdown.active .ud-chevron {
			transform: rotate(180deg);
		}
		.user-dropdown-menu {
			position: absolute;
			top: calc(100% + 8px);
			right: 0;
			min-width: 180px;
			background: #fff;
			border: 1px solid #e7e7e7;
			border-radius: 12px;
			box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
			padding: 8px 0;
			opacity: 0;
			visibility: hidden;
			transform: translateY(6px);
			transition: opacity 0.2s ease, visibility 0.2s ease, transform 0.2s ease;
			z-index: 9999;
		}
		.user-dropdown:hover .user-dropdown-menu,
		.user-dropdown.active .user-dropdown-menu {
			opacity: 1;
			visibility: visible;
			transform: translateY(0);
		}
		/* invisible bridge so mouse can travel from button to menu */
		.user-dropdown-menu::before {
			content: '';
			position: absolute;
			top: -10px;
			left: 0;
			right: 0;
			height: 10px;
		}
		.user-dropdown-item {
			display: flex;
			align-items: center;
			gap: 10px;
			width: 100%;
			padding: 10px 20px;
			font-size: 14px;
			font-weight: 500;
			color: #1C1C1C;
			background: none;
			border: none;
			cursor: pointer;
			text-decoration: none;
			transition: background 0.15s ease, color 0.15s ease;
			white-space: nowrap;
		}
		.user-dropdown-item:hover {
			background: #f5f5f5;
		}
		.user-dropdown-item svg {
			flex-shrink: 0;
		}
		.user-dropdown-item.text-danger {
			color: #dc2626;
		}
		.user-dropdown-item.text-danger:hover {
			background: #fef2f2;
			color: #b91c1c;
		}
		.user-dropdown-divider {
			height: 1px;
			background: #e7e7e7;
			margin: 4px 0;
		}

		/* Dark mode */
		.is_dark .user-dropdown-menu {
			background: #1C1C1C;
			border-color: #333;
		}
		.is_dark .user-dropdown-item {
			color: #fff;
		}
		.is_dark .user-dropdown-item:hover {
			background: #2a2a2a;
		}
		.is_dark .user-dropdown-item.text-danger {
			color: #f87171;
		}
		.is_dark .user-dropdown-item.text-danger:hover {
			background: #2a1a1a;
			color: #fca5a5;
		}
		.is_dark .user-dropdown-divider {
			background: #333;
		}

		/* ===== Nav Count Badge */
		.nav-count-badge {
			position: absolute;
			top: -6px;
			right: -6px;
			min-width: 18px;
			height: 18px;
			background: #FF5722;
			color: #fff;
			font-size: 11px;
			font-weight: 700;
			border-radius: 50%;
			display: flex;
			align-items: center;
			justify-content: center;
			line-height: 1;
			padding: 0 4px;
		}

		/* Disable the CSS ::after pseudo-badge (green) — we use our own <span> badge */
		.header .header-action-btn.header-action-icon::after {
			display: none !important;
		}

		/* ===== Auth Toast */
		.auth-toast {
			position: fixed;
			top: 20px;
			right: 20px;
			z-index: 99999;
			display: flex;
			align-items: center;
			gap: 12px;
			padding: 14px 20px;
			border-radius: 10px;
			font-size: 14px;
			font-weight: 500;
			box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
			animation: toastSlideIn 0.35s ease;
			max-width: 420px;
		}
		.auth-toast--success {
			background: #ecfdf5;
			color: #065f46;
			border: 1px solid #a7f3d0;
		}
		.auth-toast--error {
			background: #fef2f2;
			color: #991b1b;
			border: 1px solid #fecaca;
		}
		.auth-toast button {
			background: none;
			border: none;
			font-size: 18px;
			cursor: pointer;
			color: inherit;
			padding: 0;
			line-height: 1;
			opacity: 0.6;
		}
		.auth-toast button:hover {
			opacity: 1;
		}
		@@keyframes toastSlideIn {
			from { transform: translateX(100%); opacity: 0; }
			to   { transform: translateX(0);    opacity: 1; }
		}

		/* ===== Mobile Action Icons Grid ===== */
		.mobile-action-icons {
			display: none;
			padding: 20px 16px;
			border-top: 1px solid #e7e7e7;
		}
		.mobile-action-icons .mobile-icons-grid {
			display: grid;
			grid-template-columns: repeat(4, 1fr);
			gap: 16px 12px;
		}
		.mobile-action-icons .mobile-icon-item {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 6px;
			text-decoration: none;
			color: #1C1C1C;
			padding: 10px 4px;
			border-radius: 12px;
			transition: background 0.15s ease;
			position: relative;
		}
		.mobile-action-icons .mobile-icon-item:hover {
			background: #f5f5f5;
		}
		.mobile-action-icons .mobile-icon-item .mobile-icon-wrap {
			width: 44px;
			height: 44px;
			border-radius: 50%;
			background: #f3f4f6;
			display: flex;
			align-items: center;
			justify-content: center;
			position: relative;
			transition: background 0.2s ease;
		}
		.mobile-action-icons .mobile-icon-item:hover .mobile-icon-wrap {
			background: #fff5f2;
		}
		.mobile-action-icons .mobile-icon-item .mobile-icon-label {
			font-size: 11px;
			font-weight: 600;
			text-align: center;
			line-height: 1.2;
			color: #4b5563;
		}
		.mobile-action-icons .mobile-icon-item .mobile-icon-badge {
			position: absolute;
			top: -4px;
			right: -4px;
			min-width: 18px;
			height: 18px;
			background: #FF5722;
			color: #fff;
			font-size: 10px;
			font-weight: 700;
		border-radius: 50%;
			display: flex;
			align-items: center;
			justify-content: center;
			line-height: 1;
			padding: 0 4px;
		}

		/* Show mobile action icons only inside mobile nav */
		#main-nav-mobile .mobile-action-icons,
		#main-nav.mobile-action-icons-container .mobile-action-icons {
			display: block;
		}

		/* Hide original header-actions on mobile */
		@@media (max-width: 1199px) {
			.header-actions {
				display: none !important;
			}
		}

		/* Dark mode for mobile action icons */
		.is_dark .mobile-action-icons {
			border-top-color: #333;
		}
		.is_dark .mobile-action-icons .mobile-icon-item {
			color: #fff;
		}
		.is_dark .mobile-action-icons .mobile-icon-item:hover {
			background: #2a2a2a;
		}
		.is_dark .mobile-action-icons .mobile-icon-wrap {
			background: #2a2a2a;
		}
		.is_dark .mobile-action-icons .mobile-icon-item:hover .mobile-icon-wrap {
			background: #3a2a2a;
		}
		.is_dark .mobile-action-icons .mobile-icon-label {
			color: #9ca3af;
		}
		.is_dark .mobile-action-icons .mobile-icon-item svg path,
		.is_dark .mobile-action-icons .mobile-icon-item svg rect,
		.is_dark .mobile-action-icons .mobile-icon-item svg circle {
			stroke: #fff;
			fill: none;
		}
		.is_dark .mobile-action-icons .mobile-icon-item svg circle[fill="#1C1C1C"] {
			fill: #fff;
			stroke: none;
		}
	</style>
</head>
<body>
	<!-- preloade -->
	<div class="preload preload-container">
		<img class="preload--icon" src="~/assets/icons/preload.svg" alt="preload">
	</div>
	<!-- preload -->

	@{
		var currentUser = SignInManager.IsSignedIn(User) ? await UserManager.GetUserAsync(User) : null;
		var sessionId   = Context.Session.Id;
		var compareCount = await CompareService.GetCountAsync(sessionId);
		var wishlistCount = await WishlistService.GetCountAsync(sessionId);
		var notifCount = currentUser != null ? await NotificationService.GetUnreadCountAsync(currentUser.Id) : 0;

		// Active nav detection
		var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
		var currentArea = ViewContext.RouteData.Values["area"]?.ToString() ?? "";
		bool isHome   = currentController == "Home" && string.IsNullOrEmpty(currentArea);
		bool isAbout  = currentController == "About" && string.IsNullOrEmpty(currentArea);
		bool isList   = currentController == "List" && string.IsNullOrEmpty(currentArea);
		bool isBlog   = currentController == "Blog" && string.IsNullOrEmpty(currentArea);
		bool isContact= currentController == "Contact" && string.IsNullOrEmpty(currentArea);
		bool isProduct= currentController == "Product" && string.IsNullOrEmpty(currentArea);
		bool isPages  = !isHome && !isAbout && !isList && !isBlog && !isContact && !isProduct && string.IsNullOrEmpty(currentArea);
	}

	@* Toast bildirişləri *@
	@if (TempData["AuthSuccess"] != null)
	{
		<div id="auth-toast" class="auth-toast auth-toast--success">
			<span>@TempData["AuthSuccess"]</span>
			<button onclick="document.getElementById('auth-toast').remove()">✕</button>
		</div>
	}
	@if (TempData["AuthError"] != null)
	{
		<div id="auth-toast" class="auth-toast auth-toast--error">
			<span>@TempData["AuthError"]</span>
			<button onclick="document.getElementById('auth-toast').remove()">✕</button>
		</div>
	}

	<div id="wrapper">

		<!-- Header -->
		<div class="header-wrapper">
			<header class="header bg-white header-style-1" id="header_main">
				<div class="header-container-fluid max-w-1920 relative header-primary">
					<div class="header-inner" id="site-header-inner">
						<div class="logo">
							<a asp-controller="Home" asp-action="Index">
								<img src="~/assets/images/logo.png" alt="logo">
							</a>
						</div>
						<div class="logo-mobile">
							<a asp-controller="Home" asp-action="Index">
								<img src="~/assets/images/logo-white.png" alt="logo">
							</a>
						</div>

						<div class="header-right main-nav-wrapper gap-20">
							<!-- Menu -->
							<nav id="main-nav" class="main-nav mr-18">
								<ul id="menu-primary-menu" class="menu">
									<li class="menu-item menu-item-has-children menu-item--static menu-item-main @(isHome ? "current-menu-item" : "")">
										<a asp-controller="Home" asp-action="Index">Home</a>
									</li>
									<li class="menu-item @(isAbout ? "current-menu-item" : "")">
										<a asp-controller="About" asp-action="Index">About</a>
									</li>
									<li class="menu-item menu-item-has-children menu-item--static @(isList ? "current-menu-item" : "")">
										<a asp-controller="List" asp-action="Index">List</a>
									</li>
									<li class="menu-item @(isProduct ? "current-menu-item" : "")">
										<a asp-controller="Product" asp-action="Index">Products</a>
									</li>
									<li class="menu-item menu-item-has-children @(isBlog ? "current-menu-item" : "")">
										<a asp-controller="Blog" asp-action="Index">
											Blog
										</a>
									</li>

									<li class="menu-item @(isContact ? "current-menu-item" : "")">
										<a asp-controller="Contact" asp-action="Index">Contact</a>
									</li>
								</ul>

								<!-- Mobile Action Icons (visible only in mobile menu) -->
								<div class="mobile-action-icons">
									<div class="mobile-icons-grid">
										<a asp-controller="Calculator" asp-action="Index" class="mobile-icon-item">
											<div class="mobile-icon-wrap">
												<svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
													<rect x="4" y="2" width="16" height="20" rx="2" ry="2" stroke="#1C1C1C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
													<rect x="7" y="5" width="10" height="4" rx="1" stroke="#1C1C1C" stroke-width="1.5"/>
													<circle cx="8" cy="13" r="1" fill="#1C1C1C"/>
													<circle cx="12" cy="13" r="1" fill="#1C1C1C"/>
													<circle cx="16" cy="13" r="1" fill="#1C1C1C"/>
													<circle cx="8" cy="17" r="1" fill="#1C1C1C"/>
													<circle cx="12" cy="17" r="1" fill="#1C1C1C"/>
													<circle cx="16" cy="17" r="1" fill="#1C1C1C"/>
												</svg>
											</div>
											<span class="mobile-icon-label">Kalkulyator</span>
										</a>
										<a asp-controller="Payment" asp-action="Index" class="mobile-icon-item">
											<div class="mobile-icon-wrap">
												<svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
													<path d="M6 2L3 6V20C3 20.5304 3.21071 21.0391 3.58579 21.4142C3.96086 21.7893 4.46957 22 5 22H19C19.5304 22 20.0391 21.7893 20.4142 21.4142C20.7893 21.0391 21 20.5304 21 20V6L18 2H6Z" stroke="#1C1C1C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
													<path d="M3 6H21" stroke="#1C1C1C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
													<path d="M16 10C16 11.0609 15.5786 12.0783 14.8284 12.8284C14.0783 13.5786 13.0609 14 12 14C10.9391 14 9.92172 13.5786 9.17157 12.8284C8.42143 12.0783 8 11.0609 8 10" stroke="#1C1C1C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
												</svg>
											</div>
											<span class="mobile-icon-label">Səbət</span>
										</a>
										<a asp-controller="Compare" asp-action="Index" class="mobile-icon-item">
											<div class="mobile-icon-wrap">
												<svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
													<path d="M16.5 13.5L19.5 16.5L16.5 19.5" stroke="#1C1C1C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
													<path d="M4.5 16.5H19.5" stroke="#1C1C1C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
													<path d="M7.5 10.5L4.5 7.5L7.5 4.5" stroke="#1C1C1C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
													<path d="M19.5 7.5H4.5" stroke="#1C1C1C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
												</svg>
												@if (compareCount > 0)
												{
													<span class="mobile-icon-badge">@compareCount</span>
												}
											</div>
											<span class="mobile-icon-label">Müqayisə</span>
										</a>
										<a asp-controller="Wishlist" asp-action="Index" class="mobile-icon-item">
											<div class="mobile-icon-wrap">
												<svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
													<path d="M12 21C12 21 2.25 15.75 2.25 9.5625C2.25 8.21984 2.78337 6.93217 3.73277 5.98277C4.68217 5.03337 5.96984 4.5 7.3125 4.5C9.43031 4.5 11.2444 5.65406 12 7.5C12.7556 5.65406 14.5697 4.5 16.6875 4.5C18.0302 4.5 19.3178 5.03337 20.2672 5.98277C21.2166 6.93217 21.75 8.21984 21.75 9.5625C21.75 15.75 12 21 12 21Z" stroke="#1C1C1C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
											</div>
											@if (wishlistCount > 0)
											{
												<span class="mobile-icon-badge">@wishlistCount</span>
											}
										</a>
										@if (currentUser != null)
										{
											<a asp-controller="Notification" asp-action="Index" class="mobile-icon-item">
												<div class="mobile-icon-wrap">
													<svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
														<path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" stroke="#1C1C1C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
														<path d="M13.73 21a2 2 0 0 1-3.46 0" stroke="#1C1C1C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
													</svg>
													@if (notifCount > 0)
													{
														<span class="mobile-icon-badge">@notifCount</span>
													}
												</div>
												<span class="mobile-icon-label">Bildirişlər</span>
											</a>
											<a asp-controller="Message" asp-action="Index" class="mobile-icon-item">
												<div class="mobile-icon-wrap">
													<svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
														<path d="M21 15C21 15.5304 20.7893 16.0391 20.4142 16.4142C20.0391 16.7893 19.5304 17 19 17H7L3 21V5C3 4.46957 3.21071 3.96086 3.58579 3.58579C3.96086 3.21071 4.46957 3 5 3H19C19.5304 3 20.0391 3.21071 20.4142 3.58579C20.7893 3.96086 21 4.46957 21 5V15Z" stroke="#1C1C1C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
													</svg>
												</div>
												<span class="mobile-icon-label">Mesajlar</span>
											</a>
										}
									</div>
								</div>
								<!-- /Mobile Action Icons -->
							</nav>
							<!-- /Menu -->

							<div class="header-button mobile-hidden-header-button flex items-center gap-20">
								@if (currentUser != null)
								{
									<div class="user-dropdown">
										<button type="button" class="btn btn-line btn-large font-weight-600 bg-sign-in user-dropdown-toggle">
											<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
												<g clip-path="url(#clip0_user_d)">
													<path d="M12 15C15.3137 15 18 12.3137 18 9C18 5.68629 15.3137 3 12 3C8.68629 3 6 5.68629 6 9C6 12.3137 8.68629 15 12 15Z" stroke="#1C1C1C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
													<path d="M3 20.25C4.81594 17.1122 8.11406 15 12 15C15.8859 15 19.1841 17.1122 21 20.25" stroke="#1C1C1C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
												</g>
											</svg>
											@currentUser.FullName.Split(' ')[0]
											<svg class="ud-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
												<path d="M4 6L8 10L12 6" stroke="#9FA1A4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
											</svg>
										</button>
										<div class="user-dropdown-menu">
											<a asp-controller="UserProfil" asp-action="Index" class="user-dropdown-item">
												<svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
													<path d="M12 15C15.3137 15 18 12.3137 18 9C18 5.68629 15.3137 3 12 3C8.68629 3 6 5.68629 6 9C6 12.3137 8.68629 15 12 15Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
													<path d="M3 20.25C4.81594 17.1122 8.11406 15 12 15C15.8859 15 19.1841 17.1122 21 20.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
												</svg>
												Profil
											</a>
											<a asp-controller="UserListing" asp-action="Index" class="user-dropdown-item">
												<svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
													<path d="M8 6H21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
													<path d="M8 12H21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
													<path d="M8 18H21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
