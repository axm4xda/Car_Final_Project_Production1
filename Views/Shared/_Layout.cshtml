	<div class="bg-modal"></div>
	<div class="modal-content modal-sm">
		<button class="close-modal" type="button">
			<img src="~/assets/icons/close-modal.svg" alt="close">
		</button>
		<div class="modal-container">
			<div class="modal-inner">
				<h2 class="mt-20 mb-20 text-center">Şifrəni Unutdunuz?</h2>

				<div id="forgotPasswordMsg" class="mb-16 p-12" style="border-radius:8px;display:none;"></div>

				<form asp-controller="Account" asp-action="ForgotPassword" method="post" id="forgotPasswordForm">
