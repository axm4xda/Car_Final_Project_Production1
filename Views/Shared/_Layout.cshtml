				<p class="text-sm text-secondary flex gap-8 justify-center">
					Qeydiyyatdan keçməmisiniz?
					<span class="text-sm font-weight-600 text-underline open-modal cursor-pointer"
						  data-modal-id="#SignUpModal">Qeydiyyat</span>
				</p>
			</div>
		</div>
	</div>
</div>
