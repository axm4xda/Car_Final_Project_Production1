<!-- LoginModal -->
<div id="LoginModal" class="modal modal-login">
	<div class="bg-modal"></div>
	<div class="modal-content modal-sm">
		<button class="close-modal" type="button">
			<img src="~/assets/icons/close-modal.svg" alt="close">
		</button>
		<div class="modal-container">
			<div class="modal-inner">
				<h2 class="mb-20 text-center">Daxil Ol</h2>

				<div id="loginErrorContainer" class="mb-16 p-12" style="background:#fee2e2;color:#dc2626;border-radius:8px;display:none;"></div>

				@{
					var googleReturnUrl = Uri.EscapeDataString(Context.Request.Path + Context.Request.QueryString);
				}

				<form asp-controller="Account" asp-action="Login" method="post" id="loginForm">
					@Html.AntiForgeryToken()
					<input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />

					<label for="email-login" class="mb-20 px-2">
						<span class="mb-8 flex">Email*</span>
						<input class="input-large" type="email" id="email-login" name="Email"
							   placeholder="Email daxil edin" required autocomplete="email">
					</label>

					<label for="Password-login" class="mb-24 px-2">
						<span class="flex mb-8">Şifrə*</span>
						<input class="input-large password-input is-hidden" type="password"
							   id="Password-login" name="Password"
							   placeholder="Şifrə" required minlength="8" autocomplete="current-password">
					</label>

					<div class="flex justify-between gap-12 mb-20">
						<label class="filter-checkbox style-5">
														<input type="checkbox" name="RememberMe" value="true">
							<span class="text-sm">Məni xatırla</span>
						</label>
						<span class="text-sm font-bold text-underline open-modal cursor-pointer"
							  data-modal-id="#ForgotPasswordModal">Şifrəni unutdunuz?</span>
					</div>

					<button type="submit" class="btn btn-primary btn-large w-full mb-12 font-weight-600">
						Daxil Ol
					</button>
				</form>

				<!-- Google OAuth -->
				<div class="flex items-center gap-8 my-12">
					<div style="flex:1;height:1px;background:#e5e7eb;"></div>
					<span class="text-sm text-secondary">və ya</span>
					<div style="flex:1;height:1px;background:#e5e7eb;"></div>
				</div>

				<a href="/Account/GoogleLogin?returnUrl=@googleReturnUrl"
				   class="btn btn-large w-full font-weight-600 mb-16"
				   style="border:1.5px solid #e5e7eb;background:#fff;color:#1C1C1C;display:flex;align-items:center;justify-content:center;gap:10px;">
					<svg width="20" height="20" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
						<path fill="#4285F4" d="M43.6 20.5H42V20H24v8h11.3C33.7 32.7 29.2 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3 0 5.7 1.1 7.8 2.9l5.7-5.7C34.1 6.5 29.3 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.2-.1-2.3-.4-3.5z"/>
						<path fill="#34A853" d="M6.3 14.7l6.6 4.8C14.7 16 0 19 13 24 13c3 0 5.7 1.1 7.8 2.9l5.7-5.7C34.1 6.5 29.3 4 24 4 16.1 4 9.3 8.4 6.3 14.7z"/>
						<path fill="#FBBC05" d="M24 44c5.2 0 9.9-1.8 13.5-4.8l-6.2-5.2C29.2 35.6 26.7 36.5 24 36.5c-5.1 0-9.5-3.2-11.2-7.7L6.2 34c3.1 6.4 9.8 10 17.8 10z"/>
						<path fill="#EA4335" d="M43.6 20.5H42V20H24v8h11.3c-.9 2.5-2.5 4.6-4.6 6l6.2 5.2C40.9 35.7 44 30.3 44 24c0-1.2-.1-2.3-.4-3.5z"/>
					</svg>
					Google ilə Daxil Ol
				</a>

				<p class="text-sm text-secondary flex gap-8 justify-center">
					Qeydiyyatdan keçməmisiniz?
					<span class="text-sm font-weight-600 text-underline open-modal cursor-pointer"
						  data-modal-id="#SignUpModal">Qeydiyyat</span>
				</p>
			</div>
		</div>
	</div>
</div>

<!-- SignUpModal -->
<div id="SignUpModal" class="modal modal-login">
	<div class="bg-modal"></div>
	<div class="modal-content modal-sm">
		<button class="close-modal" type="button">
			<img src="~/assets/icons/close-modal.svg" alt="close">
		</button>
		<div class="modal-container">
			<div class="modal-inner">
				<h2 class="mb-20 text-center">Qeydiyyat</h2>

				<div id="registerErrorContainer" class="mb-16 p-12" style="background:#fee2e2;color:#dc2626;border-radius:8px;display:none;"></div>

				<form asp-controller="Account" asp-action="Register" method="post" id="registerForm">
					@Html.AntiForgeryToken()
					<input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />

					<!-- Rol Seçimi -->
					<div class="flex gap-12 mb-20 px-2">
						<label class="role-selector flex-1" style="cursor:pointer;">
							<input type="radio" name="Role" id="role-user" value="User" checked style="display:none;">
							<div id="role-user-box" style="border:2px solid #FF5722;border-radius:10px;padding:12px 16px;text-align:center;background:#fff5f2;transition:border-color 0.2s,background 0.2s;">
								<p style="font-size:22px;margin-bottom:4px;">👤</p>
								<p style="font-size:13px;font-weight:600;margin:0;">İstifadəçi</p>
								<p style="font-size:11px;color:#9ca3af;margin:2px 0 0;">Avtomobil al / sat</p>
							</div>
						</label>
						<label class="role-selector flex-1" style="cursor:pointer;">
							<input type="radio" name="Role" id="role-agent" value="Agent" style="display:none;">
							<div id="role-agent-box" style="border:2px solid #e0e0e0;border-radius:10px;padding:12px 16px;text-align:center;background:#fff;transition:border-color 0.2s,background 0.2s;">
								<p style="font-size:22px;margin-bottom:4px;">🔑</p>
								<p style="font-size:13px;font-weight:600;margin:0;">Agent</p>
								<p style="font-size:11px;color:#9ca3af;margin:2px 0 0;">Avtomobil kiralayıcı</p>
							</div>
						</label>
					</div>

					<label for="email-register" class="mb-20 px-2">
						<span class="mb-8 flex">Email*</span>
						<input class="input-large" type="email" id="email-register" name="Email"
							   placeholder="Email daxil edin" required autocomplete="email">
					</label>

					<label for="fullName-register" class="mb-20 px-2">
						<span class="mb-8 flex">Ad, Soyad*</span>
						<input class="input-large" type="text" id="fullName-register" name="FullName"
							   placeholder="Ad, Soyad daxil edin" required>
					</label>

					<label for="password-register" class="mb-24 px-2">
						<span class="flex mb-8">Şifrə*</span>
						<input class="input-large password-input is-hidden" type="password"
							   id="password-register" name="Password"
							   placeholder="Şifrə" required minlength="8" autocomplete="new-password">
					</label>

					<label for="confirmPassword-register" class="mb-24 px-2">
						<span class="flex mb-8">Şifrəni təsdiq et*</span>
						<input class="input-large password-input is-hidden" type="password"
							   id="confirmPassword-register" name="ConfirmPassword"
							   placeholder="Şifrəni təsdiq et" required minlength="8" autocomplete="new-password">
					</label>

					<div class="flex justify-between gap-12 mb-20">
						<label class="filter-checkbox style-5">
							<input type="checkbox" name="AgreeToTerms" value="true" required>
							<span class="text-sm">
								Şərtlərlə razıyam
								<a asp-controller="Termsofuse" asp-action="Index" target="_blank" class="text-primary">
									Şərtlər
								</a>
							</span>
						</label>
					</div>

					<button type="submit" class="btn btn-primary btn-large w-full mb-12 font-weight-600">
						Qeydiyyat
					</button>

					<p class="text-sm text-secondary flex gap-8 justify-center">
						Artıq üzv varsınız?
						<span class="text-sm font-weight-600 text-underline open-modal cursor-pointer"
						  data-modal-id="#LoginModal">Daxil Ol</span>
					</p>
				</form>
			</div>
		</div>
	</div>
</div>
<!-- /SignUpModal -->

<!-- ForgotPasswordModal -->
