<!-- Scripts -->
<script src="~/assets/js/jquery.min.js"></script>
<script src="~/assets/js/jquery.cookie.min.js"></script>
<script src="~/assets/js/swiper-bundle.min.js"></script>
<script src="~/assets/js/wow.min.js"></script>
<script src="~/assets/js/jquery.fancybox.js"></script>
<script src="~/assets/js/simpleParallaxVanilla.umd.js"></script>
<script src="~/assets/js/app.js"></script>
<script src="~/assets/js/swiper.js"></script>
<script src="~/microsoft/signalr/dist/browser/signalr.min.js"></script>

<script>
	// ====== AI CHAT WIDGET ======
	(function () {
		"use strict";

		var toggle   = document.getElementById('aiChatToggle');
		var chatWin  = document.getElementById('aiChatWindow');
		var iconOpen = document.getElementById('aiChatIconOpen');
		var iconClose= document.getElementById('aiChatIconClose');
		var form     = document.getElementById('aiChatForm');
		var input    = document.getElementById('aiChatInput');
		var sendBtn  = document.getElementById('aiChatSend');
		var messages = document.getElementById('aiChatMessages');
		var typing   = document.getElementById('aiChatTyping');
		var clearBtn = document.getElementById('aiChatClear');
		var statusEl = document.getElementById('aiChatStatus');

		if (!toggle || !chatWin) return;

		var isOpen = false;
		var connection = null;
		var isConnected = false;
		var isSending = false;          // mesaj göndərilir — cavab gözlənilir
		var sendTimeoutId = null;       // safety timeout

		// Toggle chat window
		toggle.addEventListener('click', function () {
			isOpen = !isOpen;
			chatWin.style.display = isOpen ? 'flex' : 'none';
			iconOpen.style.display  = isOpen ? 'none' : 'block';
			iconClose.style.display = isOpen ? 'block' : 'none';
			if (isOpen) {
				ensureConnection();
				input.focus();
				scrollToBottom();
			}
		});

		// Ensure SignalR connection
		function ensureConnection() {
			if (connection && isConnected) return;
			if (connection) {
				// Əgər əvvəlki connection var amma kəsilib — yenisini yarat
				try { connection.stop(); } catch(e) {}
				connection = null;
			}

			connection = new signalR.HubConnectionBuilder()
				.withUrl("/aiChatHub")
				.withAutomaticReconnect([0, 2000, 5000, 10000, 30000])
				.build();

			connection.on("AiResponse", function (response) {
				// Cavab gəldi — sending state-i sıfırla
				clearSendTimeout();
				isSending = false;
				typing.style.display = 'none';
				setInputEnabled(true);
				appendMessage(response, 'bot');
				scrollToBottom();
			});

			connection.on("AiTyping", function (show) {
				typing.style.display = show ? 'block' : 'none';
				if (show) scrollToBottom();
				// AiTyping(false) gəldikdə input-u aktiv et
				if (!show) {
					isSending = false;
					clearSendTimeout();
					setInputEnabled(true);
				}
			});

			connection.on("HistoryCleared", function () {
				messages.innerHTML = '';
				appendMessage('Söhbət tarixçəsi təmizləndi. Yeni bir sual verə bilərsiniz! 🚗', 'bot');
			});

			connection.onreconnecting(function () {
				isConnected = false;
				statusEl.textContent = 'Yenidən qoşulur...';
				statusEl.style.color = '#fbbf24';
				// Reconnect zamanı stuck state-i sıfırla
				resetSendingState();
			});

			connection.onreconnected(function () {
				isConnected = true;
				statusEl.textContent = 'Online';
				statusEl.style.color = 'rgba(255,255,255,0.7)';
				resetSendingState();
			});

			connection.onclose(function () {
				isConnected = false;
				statusEl.textContent = 'Offline';
				statusEl.style.color = '#f87171';
				resetSendingState();
			});

			connection.start().then(function () {
				isConnected = true;
				statusEl.textContent = 'Online';
				statusEl.style.color = 'rgba(255,255,255,0.7)';
			}).catch(function (err) {
				console.error('AI Chat connection failed:', err);
				statusEl.textContent = 'Bağlantı xətası';
				statusEl.style.color = '#f87171';
			});
		}

		// Send message
		form.addEventListener('submit', function (e) {
			e.preventDefault();
			var text = input.value.trim();
			if (!text) return;

			// Bağlantı yoxdursa yenidən qoşulmağa çalış
			if (!isConnected) {
				ensureConnection();
				appendMessage('Bağlantı qurulur, bir az gözləyin...', 'bot');
				return;
			}

			// Artıq göndərilir — təkrar göndərmənin qarşısını al
			if (isSending) return;

			isSending = true;
			setInputEnabled(false);
			typing.style.display = 'block';
			appendMessage(text, 'user');
			input.value = '';
			scrollToBottom();

			// Safety timeout: 45 saniyə ərzində cavab gəlməsə input-u aç
			sendTimeoutId = setTimeout(function () {
				if (isSending) {
					isSending = false;
					typing.style.display = 'none';
					setInputEnabled(true);
					appendMessage('Cavab çox uzun çəkdi. Zəhmət olmasa yenidən cəhd edin.', 'bot');
					scrollToBottom();
				}
			}, 45000);

			connection.invoke("SendMessage", text).catch(function (err) {
				console.error('Send error:', err);
				clearSendTimeout();
				isSending = false;
				typing.style.display = 'none';
				setInputEnabled(true);
				appendMessage('Mesaj göndərilə bilmədi. Yenidən cəhd edin.', 'bot');
				scrollToBottom();
			});
		});

		// Clear history
		clearBtn.addEventListener('click', function () {
			if (connection && isConnected) {
				connection.invoke("ClearHistory").catch(function (err) {
					console.error('Clear error:', err);
				});
			}
		});

		function appendMessage(text, type) {
			var div = document.createElement('div');
			div.className = 'ai-msg ai-msg--' + type;

			var avatar = document.createElement('div');
			avatar.className = 'ai-msg__avatar';
			if (type === 'bot') {
				avatar.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 2C6.48 2 2 5.58 2 10c0 2.24 1.12 4.26 2.93 5.72L4 20l4.35-2.18C9.5 18.26 10.72 18.5 12 18.5c5.52 0 10-3.58 10-8S17.52 2 12 2z" fill="#FF5722"/></svg>';
			} else {
				avatar.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 15C15.3137 15 18 12.3137 18 9C18 5.68629 15.3137 3 12 3C8.68629 3 6 5.68629 6 9C6 12.3137 8.68629 15 12 15Z" stroke="white" stroke-width="2"/><path d="M3 20.25C4.81594 17.1122 8.11406 15 12 15C15.8859 15 19.1841 17.1122 21 20.25" stroke="white" stroke-width="2"/></svg>';
			}

			var bubble = document.createElement('div');
			bubble.className = 'ai-msg__bubble';
			bubble.textContent = text;

			div.appendChild(avatar);
			div.appendChild(bubble);
			messages.appendChild(div);
		}

		function scrollToBottom() {
			setTimeout(function () {
				messages.scrollTop = messages.scrollHeight;
			}, 50);
		}

		function setInputEnabled(enabled) {
			input.disabled   = !enabled;
			sendBtn.disabled = !enabled;
			if (enabled) input.focus();
		}

		function clearSendTimeout() {
			if (sendTimeoutId) {
				clearTimeout(sendTimeoutId);
				sendTimeoutId = null;
			}
		}

		function resetSendingState() {
			clearSendTimeout();
			isSending = false;
			typing.style.display = 'none';
			setInputEnabled(true);
		}
	})();

	// ====== Role Selector ======
	(function () {
		var userRadio  = document.getElementById('role-user');
		var agentRadio = document.getElementById('role-agent');
		var userBox    = document.getElementById('role-user-box');
		var agentBox   = document.getElementById('role-agent-box');

		if (!userRadio || !agentRadio) return;

		var activeStyle   = 'border:2px solid #FF5722;border-radius:10px;padding:12px 16px;text-align:center;background:#fff5f2;transition:border-color 0.2s,background 0.2s;';
		var inactiveStyle = 'border:2px solid #e5e7eb;border-radius:10px;padding:12px 16px;text-align:center;transition:border-color 0.2s,background 0.2s;';

		function updateStyles() {
			if (userRadio.checked) {
				userBox.setAttribute('style',  activeStyle);
				agentBox.setAttribute('style', inactiveStyle);
			} else {
				agentBox.setAttribute('style', activeStyle);
				userBox.setAttribute('style',  inactiveStyle);
			}
		}

		updateStyles();
		userRadio.addEventListener('change',  updateStyles);
		agentRadio.addEventListener('change', updateStyles);

		document.querySelectorAll('.role-selector').forEach(function(label) {
			label.addEventListener('click', function () {
				setTimeout(updateStyles, 0);
			});
		});
	})();

	// ====== AJAX Register Form ======
	$('#registerForm').on('submit', function(e) {
		e.preventDefault();

		var form = $(this);
		var url = form.attr('action');
		var formData = form.serialize();

		$.ajax({
			type: 'POST',
			url: url,
			data: formData,
			headers: { 'X-Requested-With': 'XMLHttpRequest' },
			success: function(response) {
				if (response.success) {
					var redirectUrl = response.redirectUrl || '/';
					window.location.href = redirectUrl;
				} else {
					$('#registerErrorContainer').html(response.message).show();
				}
			},
			error: function(xhr) {
				var errorMessage = 'Qeydiyyatda xəta baş verdi. Zəhmət olmasa, yenidən yoxlayın.';
				$('#registerErrorContainer').html(errorMessage).show();
			}
		});
	});

	// ====== AJAX Login Form ======
	$('#loginForm').on('submit', function(e) {
		e.preventDefault();

		var form = $(this);
		var url = form.attr('action');
		var formData = form.serialize();

		$.ajax({
			type: 'POST',
			url: url,
			data: formData,
			headers: { 'X-Requested-With': 'XMLHttpRequest' },
			success: function(response) {
				if (response.success) {
					var redirectUrl = response.redirectUrl || '/';
					window.location.href = redirectUrl;
				} else {
					$('#loginErrorContainer').html(response.message).show();
				}
			},
			error: function(xhr) {
				var errorMessage = 'Daxil olmada xəta baş verdi. Zəhmət olmasa, yenidən yoxlayın.';
				$('#loginErrorContainer').html(errorMessage).show();
			}
		});
	});

	// ====== Password Visibility Toggle ======
	document.querySelectorAll('.password-toggle').forEach(function(toggle) {
		toggle.addEventListener('click', function() {
			var input = this.previousElementSibling;
			var type = input.getAttribute('type') === 'password' ? 'text' : 'password';
			input.setAttribute('type', type);
			this.classList.toggle('visible');
		});
	});

	// ====== Auto-Toast dismiss ======
	(function() {
		var toast = document.getElementById('auth-toast');
		if (toast) {
			setTimeout(function() { toast.remove(); }, 5000);
		}
	})();

	// ====== Auto-Open Modal (from TempData) ======
	@if (TempData["OpenModal"] != null)
	{
		<text>
		$(function() {
			$('@TempData["OpenModal"]').addClass('active');
		});
		</text>
	}
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>